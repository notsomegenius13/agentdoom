{
  "name": "agentdoom",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check:node": "node scripts/check-node-version.cjs",
    "predev": "npm run check:node",
    "prebuild": "npm run check:node",
    "prestart": "npm run check:node",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "rm -f tsconfig.tsbuildinfo && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:validate": "vitest run lib/forge/__tests__/validate.test.ts",
    "db:migrate": "npx tsx scripts/db-migrate.ts",
    "db:seed": "npx tsx scripts/seed-tools.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@neondatabase/serverless": "^1.0.2",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.38.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.10.0",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
