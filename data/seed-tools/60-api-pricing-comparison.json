{
  "title": "AI API Pricing Comparison",
  "description": "Compare costs across GPT-4, Claude, Gemini, and more — find the cheapest model for your use case",
  "category": "utilities",
  "viralHook": "GPT-4o costs 10x less than GPT-4 for the same quality. Are you overpaying?",
  "shareability": 5,
  "primitives": [
    {
      "type": "calculator",
      "id": "api-cost",
      "props": {
        "title": "Monthly API Cost Estimator",
        "inputs": [
          { "name": "requestsPerDay", "label": "API Requests Per Day", "type": "number", "defaultValue": 1000, "min": 1, "step": 100 },
          { "name": "avgInputTokens", "label": "Avg Input Tokens/Request", "type": "number", "defaultValue": 500, "min": 1, "step": 100 },
          { "name": "avgOutputTokens", "label": "Avg Output Tokens/Request", "type": "number", "defaultValue": 200, "min": 1, "step": 50 },
          { "name": "inputCostPer1M", "label": "Input Cost ($/1M tokens)", "type": "number", "defaultValue": 3, "min": 0, "step": 0.5 },
          { "name": "outputCostPer1M", "label": "Output Cost ($/1M tokens)", "type": "number", "defaultValue": 15, "min": 0, "step": 0.5 }
        ],
        "formula": "((requestsPerDay * avgInputTokens * inputCostPer1M / 1000000) + (requestsPerDay * avgOutputTokens * outputCostPer1M / 1000000)) * 30",
        "resultLabel": "Monthly Cost",
        "resultPrefix": "$",
        "resultSuffix": "/month"
      },
      "position": 0
    },
    {
      "type": "table",
      "id": "pricing-table",
      "props": {
        "title": "Model Pricing Comparison (per 1M tokens)",
        "columns": [
          { "key": "model", "label": "Model", "sortable": true },
          { "key": "input", "label": "Input $/1M", "sortable": true },
          { "key": "output", "label": "Output $/1M", "sortable": true },
          { "key": "quality", "label": "Quality Tier", "sortable": true },
          { "key": "speed", "label": "Speed", "sortable": false }
        ],
        "data": [
          { "model": "GPT-4o", "input": "$2.50", "output": "$10.00", "quality": "High", "speed": "Fast" },
          { "model": "GPT-4o mini", "input": "$0.15", "output": "$0.60", "quality": "Good", "speed": "Very Fast" },
          { "model": "Claude Sonnet 4", "input": "$3.00", "output": "$15.00", "quality": "High", "speed": "Fast" },
          { "model": "Claude Haiku 3.5", "input": "$0.80", "output": "$4.00", "quality": "Good", "speed": "Very Fast" },
          { "model": "Claude Opus 4", "input": "$15.00", "output": "$75.00", "quality": "Highest", "speed": "Moderate" },
          { "model": "Gemini 2.0 Flash", "input": "$0.10", "output": "$0.40", "quality": "Good", "speed": "Very Fast" },
          { "model": "Gemini 2.5 Pro", "input": "$1.25", "output": "$10.00", "quality": "High", "speed": "Fast" },
          { "model": "Llama 3.1 70B", "input": "$0.50", "output": "$0.75", "quality": "Good", "speed": "Fast" },
          { "model": "Mistral Large", "input": "$2.00", "output": "$6.00", "quality": "High", "speed": "Fast" }
        ],
        "showSearch": true,
        "pageSize": 10
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "680px", "padding": "24px" },
  "theme": { "primaryColor": "#0891b2", "backgroundColor": "#ecfeff", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
