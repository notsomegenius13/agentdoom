{
  "title": "Study Session Timer",
  "description": "Pomodoro-style study timer with customizable work and break intervals — track your focus streaks",
  "category": "education",
  "viralHook": "I studied for 3 hours straight using this timer and actually retained everything",
  "shareability": 4,
  "primitives": [
    {
      "type": "timer",
      "id": "study-timer",
      "props": {
        "title": "Focus Timer",
        "modes": [
          {
            "id": "pomodoro",
            "label": "Pomodoro (25 min)",
            "duration": 1500,
            "color": "#ef4444"
          },
          {
            "id": "short-break",
            "label": "Short Break (5 min)",
            "duration": 300,
            "color": "#10b981"
          },
          {
            "id": "long-break",
            "label": "Long Break (15 min)",
            "duration": 900,
            "color": "#3b82f6"
          },
          {
            "id": "deep-work",
            "label": "Deep Work (50 min)",
            "duration": 3000,
            "color": "#8b5cf6"
          }
        ],
        "autoStartBreaks": false,
        "soundAlert": true,
        "defaultMode": "pomodoro"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "study-stats",
      "props": {
        "title": "Today's Study Stats",
        "stats": [
          {
            "id": "total-time",
            "label": "Total Study Time",
            "value": "0 min",
            "icon": "clock",
            "color": "#6366f1",
            "description": "Across all sessions today"
          },
          {
            "id": "sessions-completed",
            "label": "Sessions Completed",
            "value": "0",
            "icon": "check-circle",
            "color": "#10b981",
            "description": "Pomodoros finished today"
          },
          {
            "id": "current-streak",
            "label": "Current Streak",
            "value": "0 days",
            "icon": "fire",
            "color": "#f59e0b",
            "description": "Consecutive study days"
          },
          {
            "id": "breaks-taken",
            "label": "Breaks Taken",
            "value": "0",
            "icon": "coffee",
            "color": "#06b6d4",
            "description": "Rest intervals completed"
          }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "600px", "padding": "24px" },
  "theme": { "primaryColor": "#ef4444", "backgroundColor": "#fef2f2", "fontFamily": "'Inter', sans-serif", "borderRadius": "16px" }
}
