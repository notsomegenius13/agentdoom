{
  "title": "Daily Water Intake Tracker",
  "description": "Stay hydrated — track your water intake and build a healthy drinking habit",
  "category": "health",
  "viralHook": "75% of people are chronically dehydrated — this tool takes 5 seconds to log and keeps you on track",
  "shareability": 4,
  "primitives": [
    {
      "type": "tracker",
      "id": "water-tracker",
      "props": {
        "title": "Today's Hydration",
        "unit": "glasses",
        "unitSize": "250ml (8 oz)",
        "dailyGoal": 8,
        "currentValue": 0,
        "increments": [1, 2, 3],
        "icon": "💧",
        "milestones": [
          { "value": 2, "label": "Good start!" },
          { "value": 4, "label": "Halfway there!" },
          { "value": 6, "label": "Almost done!" },
          { "value": 8, "label": "Goal reached! 🎉" }
        ],
        "logLabel": "Add Glass",
        "resetLabel": "Reset Today"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "water-stats",
      "props": {
        "title": "Your Hydration Stats",
        "stats": [
          { "label": "Today", "value": "0 / 8 glasses", "trend": "neutral", "trendValue": "0% of daily goal" },
          { "label": "Current Streak", "value": "0 days", "trend": "neutral", "trendValue": "Personal best: 0 days" },
          { "label": "Weekly Average", "value": "0 glasses/day", "trend": "neutral", "trendValue": "Goal: 8 glasses/day" },
          { "label": "This Week Total", "value": "0 glasses", "trend": "neutral", "trendValue": "Goal: 56 glasses" }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "600px", "padding": "24px" },
  "theme": { "primaryColor": "#38bdf8", "backgroundColor": "#f0f9ff", "fontFamily": "'Inter', sans-serif", "borderRadius": "16px" }
}
