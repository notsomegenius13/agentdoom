{
  "title": "AI Text Detector",
  "description": "Paste any text and score how AI-written it sounds based on linguistic patterns",
  "category": "utilities",
  "viralHook": "Paste your college essay — is it too AI? Check before your professor does",
  "shareability": 5,
  "primitives": [
    {
      "type": "form",
      "id": "text-input",
      "props": {
        "title": "AI Vibe Check",
        "fields": [
          { "name": "text", "label": "Paste your text", "type": "textarea", "required": true, "placeholder": "Paste the text you want to analyze..." },
          { "name": "context", "label": "What kind of text?", "type": "select", "options": ["Essay / Academic", "Email / Professional", "Social Media Post", "Creative Writing", "News Article", "Other"] }
        ],
        "submitLabel": "Detect AI"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "detection-results",
      "props": {
        "title": "Detection Results",
        "stats": [
          { "label": "AI Probability", "value": "—%", "change": 0, "changeLabel": "submit text to analyze", "icon": "percent" },
          { "label": "Vocabulary Diversity", "value": "—", "change": 0, "changeLabel": "unique words ratio", "icon": "trending" },
          { "label": "Sentence Uniformity", "value": "—", "change": 0, "changeLabel": "length variation", "icon": "dollar" },
          { "label": "Hedging Score", "value": "—", "change": 0, "changeLabel": "qualifiers & filler", "icon": "cart" }
        ]
      },
      "position": 1
    },
    {
      "type": "table",
      "id": "pattern-breakdown",
      "props": {
        "title": "Pattern Analysis",
        "columns": [
          { "key": "pattern", "label": "Pattern", "sortable": false },
          { "key": "found", "label": "Found", "sortable": true },
          { "key": "signal", "label": "AI Signal", "sortable": true }
        ],
        "data": [
          { "pattern": "Repetitive sentence starters", "found": "—", "signal": "—" },
          { "pattern": "Overuse of 'Furthermore/Moreover'", "found": "—", "signal": "—" },
          { "pattern": "Perfect paragraph structure", "found": "—", "signal": "—" },
          { "pattern": "Lack of contractions", "found": "—", "signal": "—" },
          { "pattern": "Generic conclusions", "found": "—", "signal": "—" },
          { "pattern": "Hedging language", "found": "—", "signal": "—" }
        ],
        "showSearch": false,
        "pageSize": 10
      },
      "position": 2
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "640px", "padding": "24px" },
  "theme": { "primaryColor": "#8b5cf6", "backgroundColor": "#f5f3ff", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
