{
  "title": "Coin Flip Simulator",
  "description": "Flip coins in bulk and see how probability plays out in real life",
  "category": "games",
  "viralHook": "Flip 1,000 coins and watch the Law of Large Numbers prove itself before your eyes",
  "shareability": 4,
  "primitives": [
    {
      "type": "form",
      "id": "coin-flip-form",
      "props": {
        "title": "Configure Your Flip",
        "fields": [
          {
            "name": "flips",
            "label": "Number of Flips",
            "type": "number",
            "defaultValue": 100,
            "min": 1,
            "max": 10000,
            "placeholder": "e.g. 100"
          },
          {
            "name": "bias",
            "label": "Coin Bias (Heads %)",
            "type": "number",
            "defaultValue": 50,
            "min": 1,
            "max": 99,
            "suffix": "%",
            "helpText": "50% = fair coin. Change to simulate a weighted coin."
          },
          {
            "name": "mode",
            "label": "Simulation Speed",
            "type": "select",
            "options": ["Instant", "Animated (slow)", "Animated (fast)"],
            "defaultValue": "Instant"
          }
        ],
        "submitLabel": "Flip Coins"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "coin-flip-stats",
      "props": {
        "title": "Flip Results",
        "stats": [
          { "label": "Heads", "value": "0", "trend": "neutral", "trendValue": "0% of flips" },
          { "label": "Tails", "value": "0", "trend": "neutral", "trendValue": "0% of flips" },
          { "label": "Longest Heads Streak", "value": "0", "trend": "neutral", "trendValue": "In current run" },
          { "label": "Longest Tails Streak", "value": "0", "trend": "neutral", "trendValue": "In current run" },
          { "label": "Deviation from 50%", "value": "0%", "trend": "neutral", "trendValue": "Expected: 0% for fair coin" },
          { "label": "Total Flips", "value": "0", "trend": "neutral", "trendValue": "Ready to flip" }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "640px", "padding": "24px" },
  "theme": { "primaryColor": "#f97316", "backgroundColor": "#1c1917", "fontFamily": "'Inter', sans-serif", "borderRadius": "16px" }
}
