    {
      "type": "tracker",
      "id": "financial-goals",
      "props": {
        "title": "Financial Goals",
        "items": [
          { "name": "Emergency Fund — $17,500 / $25,000 target", "icon": "🛡️", "target": 25000 },
          { "name": "Vacation Fund — $2,800 / $5,000 target", "icon": "✈️", "target": 5000 },
          { "name": "New Car Fund — $6,200 / $15,000 target", "icon": "🚗", "target": 15000 },
          { "name": "Student Loan Payoff — $32,000 remaining", "icon": "🎓", "target": 1 }
        ],
        "period": "monthly",
        "showStreak": false
      },
      "position": 3
    },
    {
      "type": "calculator",
      "id": "savings-calculator",
      "props": {
        "title": "Quick Savings Calculator",
        "inputs": [
          { "name": "monthlyIncome", "label": "Monthly Income ($)", "type": "number", "defaultValue": 6500, "min": 0, "step": 100 },
          { "name": "savingsRate", "label": "Savings Rate (%)", "type": "number", "defaultValue": 30, "min": 0, "max": 100 },
          { "name": "months", "label": "Time Period (months)", "type": "number", "defaultValue": 24, "min": 1, "max": 360 }
        ],
        "formula": "monthlyIncome * (savingsRate / 100) * months",
        "resultLabel": "Total Saved (without interest)",
        "resultPrefix": "$",
        "resultSuffix": ""
      },
      "position": 4
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "960px", "padding": "24px" },
  "theme": { "primaryColor": "#059669", "backgroundColor": "#ecfdf5", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}