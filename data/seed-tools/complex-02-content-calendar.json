{
  "title": "Content Calendar",
  "description": "Plan, schedule, and track your content across platforms with a visual calendar and post manager",
  "category": "creator",
  "primitives": [
    {
      "type": "form",
      "id": "new-post",
      "props": {
        "title": "Schedule New Post",
        "fields": [
          { "name": "title", "label": "Post Title", "type": "text", "placeholder": "10 Tips for Better SEO", "required": true },
          { "name": "platform", "label": "Platform", "type": "select", "options": ["Instagram", "Twitter/X", "LinkedIn", "TikTok", "YouTube", "Blog"], "required": true },
          { "name": "type", "label": "Content Type", "type": "select", "options": ["Image", "Video", "Carousel", "Story", "Reel", "Article"], "required": true },
          { "name": "date", "label": "Publish Date", "type": "date", "required": true },
          { "name": "caption", "label": "Caption / Description", "type": "textarea", "placeholder": "Write your post content..." },
          { "name": "hashtags", "label": "Hashtags", "type": "text", "placeholder": "#marketing #growth" }
        ],
        "submitLabel": "Schedule Post",
        "successMessage": "Post scheduled!"
      },
      "position": 0
    },
    {
      "type": "table",
      "id": "scheduled-posts",
      "props": {
        "title": "Scheduled Posts",
        "columns": [
          { "key": "date", "label": "Date", "sortable": true },
          { "key": "platform", "label": "Platform", "sortable": true },
          { "key": "title", "label": "Title", "sortable": false },
          { "key": "type", "label": "Type", "sortable": true },
          { "key": "status", "label": "Status", "sortable": true }
        ],
        "data": [
          { "date": "2026-04-02", "platform": "Instagram", "title": "Product launch teaser", "type": "Reel", "status": "📝 Draft" },
          { "date": "2026-04-03", "platform": "LinkedIn", "title": "Industry insights Q1 recap", "type": "Article", "status": "✅ Ready" },
          { "date": "2026-04-04", "platform": "Twitter/X", "title": "Tips thread: productivity hacks", "type": "Carousel", "status": "✅ Ready" },
          { "date": "2026-04-05", "platform": "TikTok", "title": "Behind the scenes office tour", "type": "Video", "status": "📝 Draft" },
          { "date": "2026-04-07", "platform": "Blog", "title": "How we grew 300% in 6 months", "type": "Article", "status": "⏳ In Review" },
          { "date": "2026-04-08", "platform": "Instagram", "title": "Customer testimonial spotlight", "type": "Image", "status": "✅ Ready" }
        ],
        "showSearch": true,
        "pageSize": 10
      },
      "position": 1
    },
    {
      "type": "card-grid",
      "id": "platform-stats",
      "props": {
        "title": "Platform Performance",
        "cards": [
          { "title": "Instagram", "description": "12.4K followers · 4.2% engagement · 8 posts/mo", "icon": "📸", "tag": "Primary" },
          { "title": "Twitter/X", "description": "5.8K followers · 2.1% engagement · 15 posts/mo", "icon": "🐦", "tag": "Growing" },
          { "title": "LinkedIn", "description": "3.2K followers · 6.8% engagement · 4 posts/mo", "icon": "💼", "tag": "B2B" },
          { "title": "TikTok", "description": "22.1K followers · 8.5% engagement · 6 posts/mo", "icon": "🎵", "tag": "Viral" },
          { "title": "YouTube", "description": "1.8K subscribers · 12% avg watch · 2 videos/mo", "icon": "▶️", "tag": "Long-form" },
          { "title": "Blog", "description": "4.5K monthly visitors · 3:20 avg read time", "icon": "✍️", "tag": "SEO" }
        ],
        "columns": 3
      },
      "position": 2
    },
    {
      "type": "checklist",
      "id": "weekly-tasks",
      "props": {
        "title": "Weekly Content Tasks",
        "categories": [
          { "name": "Monday", "items": ["Review analytics from last week", "Plan this week's content themes", "Respond to comments/DMs"] },
          { "name": "Wednesday", "items": ["Film/shoot content for the week", "Write blog draft", "Schedule posts for Thu-Sun"] },
          { "name": "Friday", "items": ["Review scheduled posts", "Engage with community", "Update content calendar for next week"] }
        ],
        "showProgress": true
      },
      "position": 3
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "900px", "padding": "24px" },
  "theme": { "primaryColor": "#8b5cf6", "backgroundColor": "#faf5ff", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
