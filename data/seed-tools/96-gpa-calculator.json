          },
          {
            "id": "cumulative_gpa",
            "label": "Cumulative GPA (if previous GPA provided)",
            "formula": "prev_gpa && prev_credits ? (((prev_gpa * prev_credits) + ((course1_credits * course1_grade) + (course2_credits * course2_grade) + ((course3_credits || 0) * (course3_grade || 0)) + ((course4_credits || 0) * (course4_grade || 0)) + ((course5_credits || 0) * (course5_grade || 0)) + ((course6_credits || 0) * (course6_grade || 0)))) / (prev_credits + course1_credits + course2_credits + (course3_credits || 0) + (course4_credits || 0) + (course5_credits || 0) + (course6_credits || 0))) : 0",
