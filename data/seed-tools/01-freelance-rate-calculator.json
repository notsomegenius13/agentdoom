{
  "title": "Freelance Rate Calculator",
  "description": "Find your ideal hourly rate based on salary goals and expenses",
  "category": "money",
  "primitives": [
    {
      "type": "calculator",
      "id": "freelance-rate",
      "props": {
        "title": "Freelance Rate Calculator",
        "inputs": [
          { "name": "annualGoal", "label": "Desired Annual Income ($)", "type": "number", "defaultValue": 80000, "min": 0, "step": 1000 },
          { "name": "expenses", "label": "Annual Business Expenses ($)", "type": "number", "defaultValue": 12000, "min": 0, "step": 500 },
          { "name": "taxRate", "label": "Tax Rate (%)", "type": "number", "defaultValue": 30, "min": 0, "max": 60 },
          { "name": "billableHours", "label": "Billable Hours/Week", "type": "number", "defaultValue": 30, "min": 1, "max": 60 },
          { "name": "weeksOff", "label": "Weeks Off/Year", "type": "number", "defaultValue": 4, "min": 0, "max": 20 }
        ],
        "formula": "((annualGoal + expenses) / (1 - taxRate / 100)) / ((52 - weeksOff) * billableHours)",
        "resultLabel": "Hourly Rate",
        "resultPrefix": "$",
        "resultSuffix": "/hr"
      },
      "position": 0
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "480px", "padding": "24px" },
  "theme": { "primaryColor": "#10b981", "backgroundColor": "#f0fdf4", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
