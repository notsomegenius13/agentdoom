{
  "title": "Coffee Addiction Calculator",
  "description": "How much do you spend on coffee per year? And how much caffeine is coursing through your veins?",
  "category": "fun",
  "viralHook": "3 coffees a day = $5,475/year. That's a vacation you're drinking.",
  "shareability": 5,
  "primitives": [
    {
      "type": "calculator",
      "id": "coffee-cost",
      "props": {
        "title": "Coffee Addiction Calculator",
        "inputs": [
          { "name": "cupsPerDay", "label": "Cups Per Day", "type": "number", "defaultValue": 3, "min": 0, "max": 15 },
          { "name": "costPerCup", "label": "Cost Per Cup ($)", "type": "number", "defaultValue": 5, "min": 0, "max": 15, "step": 0.5 },
          { "name": "caffeinePerCup", "label": "Caffeine Per Cup (mg)", "type": "number", "defaultValue": 95, "min": 0, "max": 500, "step": 5 },
          { "name": "yearsOfDrinking", "label": "Years You've Been Drinking Coffee", "type": "number", "defaultValue": 10, "min": 0, "max": 60 }
        ],
        "formula": "cupsPerDay * costPerCup * 365",
        "resultLabel": "Annual Coffee Spend",
        "resultPrefix": "$",
        "resultSuffix": "/year"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "coffee-stats",
      "props": {
        "title": "Your Coffee Life (at 3 cups/day, 10 years)",
        "stats": [
          { "label": "Lifetime Spent", "value": "$54,750", "change": 0, "changeLabel": "on bean water", "icon": "dollar" },
          { "label": "Cups Consumed", "value": "10,950", "change": 0, "changeLabel": "in your lifetime", "icon": "cart" },
          { "label": "Daily Caffeine", "value": "285mg", "change": 0, "changeLabel": "FDA limit: 400mg", "icon": "trending" },
          { "label": "Lifetime Caffeine", "value": "2.3 lbs", "change": 0, "changeLabel": "pure caffeine powder", "icon": "percent" }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "500px", "padding": "24px" },
  "theme": { "primaryColor": "#92400e", "backgroundColor": "#fef3c7", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
