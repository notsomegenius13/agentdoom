{
  "title": "Password Strength Checker",
  "description": "How long would it take a hacker to crack your password? Find out instantly.",
  "category": "utilities",
  "viralHook": "Your password '12345678' would be cracked in 0.001 seconds. Check yours.",
  "shareability": 5,
  "primitives": [
    {
      "type": "form",
      "id": "password-input",
      "props": {
        "title": "Check Your Password Strength",
        "fields": [
          { "name": "password", "label": "Enter a password to test", "type": "text", "required": true, "placeholder": "Don't use your real password — make a similar one" },
          { "name": "reuse", "label": "Do you reuse this password?", "type": "select", "options": ["No, it's unique", "On a few sites", "Everywhere (yikes)"] }
        ],
        "submitLabel": "Analyze Strength"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "strength-results",
      "props": {
        "title": "Password Analysis",
        "stats": [
          { "label": "Strength", "value": "—", "change": 0, "changeLabel": "submit to test", "icon": "trending" },
          { "label": "Crack Time", "value": "—", "change": 0, "changeLabel": "brute force estimate", "icon": "percent" },
          { "label": "Entropy", "value": "— bits", "change": 0, "changeLabel": "higher = better", "icon": "dollar" },
          { "label": "Verdict", "value": "—", "change": 0, "changeLabel": "safe or change it?", "icon": "cart" }
        ]
      },
      "position": 1
    },
    {
      "type": "table",
      "id": "crack-times",
      "props": {
        "title": "Crack Time Reference",
        "columns": [
          { "key": "type", "label": "Password Type", "sortable": false },
          { "key": "example", "label": "Example", "sortable": false },
          { "key": "crackTime", "label": "Time to Crack", "sortable": true }
        ],
        "data": [
          { "type": "6 digits", "example": "123456", "crackTime": "Instant" },
          { "type": "8 lowercase", "example": "password", "crackTime": "5 seconds" },
          { "type": "8 mixed case", "example": "PaSsWoRd", "crackTime": "22 minutes" },
          { "type": "10 mixed + numbers", "example": "P4ssW0rd12", "crackTime": "1 month" },
          { "type": "12 mixed + symbols", "example": "P@ssW0rd!2#4", "crackTime": "34,000 years" },
          { "type": "4 random words", "example": "correct-horse-battery-staple", "crackTime": "550 years" }
        ],
        "showSearch": false,
        "pageSize": 10
      },
      "position": 2
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "580px", "padding": "24px" },
  "theme": { "primaryColor": "#dc2626", "backgroundColor": "#fef2f2", "fontFamily": "'JetBrains Mono', monospace", "borderRadius": "12px" }
}
