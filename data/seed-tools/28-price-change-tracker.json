{
  "title": "Price Change Tracker",
  "description": "See how much everyday prices have changed in your area since any year",
  "category": "money",
  "viralHook": "Try your city → What did prices look like when you graduated?",
  "shareability": 5,
  "primitives": [
    {
      "type": "form",
      "id": "price-inputs",
      "props": {
        "title": "Check Price Changes",
        "fields": [
          { "name": "city", "label": "Your City", "type": "select", "options": ["New York", "Los Angeles", "Chicago", "Houston", "Phoenix", "Philadelphia", "San Antonio", "San Diego", "Dallas", "Austin", "San Francisco", "Seattle", "Denver", "Miami", "Atlanta", "Boston", "Portland", "Nashville", "Other"], "required": true },
          { "name": "baseYear", "label": "Compare From Year", "type": "select", "options": ["2015", "2016", "2017", "2018", "2019", "2020", "2021", "2022", "2023", "2024", "2025"], "required": true }
        ],
        "submitLabel": "Show Changes"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "price-overview",
      "props": {
        "title": "Price Changes Since 2020",
        "stats": [
          { "label": "Groceries", "value": "+23%", "change": 23, "changeLabel": "since 2020", "icon": "cart" },
          { "label": "Gas", "value": "+41%", "change": 41, "changeLabel": "since 2020", "icon": "dollar" },
          { "label": "Rent", "value": "+32%", "change": 32, "changeLabel": "since 2020", "icon": "trending" },
          { "label": "Dining Out", "value": "+28%", "change": 28, "changeLabel": "since 2020", "icon": "dollar" }
        ],
        "charts": [
          {
            "type": "bar",
            "title": "Category Price Change (%)",
            "data": [
              { "label": "Groceries", "value": 23 },
              { "label": "Gas", "value": 41 },
              { "label": "Rent", "value": 32 },
              { "label": "Dining", "value": 28 },
              { "label": "Utilities", "value": 19 },
              { "label": "Healthcare", "value": 15 }
            ]
          }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "640px", "padding": "24px" },
  "theme": { "primaryColor": "#ef4444", "backgroundColor": "#fef2f2", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
