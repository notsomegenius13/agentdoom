{
  "title": "Meditation Timer",
  "description": "A calm, configurable meditation timer with bell intervals and ambient sound options",
  "category": "health",
  "viralHook": "10 minutes of meditation daily reduces stress by 30% — this timer makes it effortless",
  "shareability": 4,
  "primitives": [
    {
      "type": "form",
      "id": "meditation-config",
      "props": {
        "title": "Set Up Your Session",
        "fields": [
          {
            "name": "duration",
            "label": "Session Duration",
            "type": "select",
            "options": ["5 minutes", "10 minutes", "15 minutes", "20 minutes", "30 minutes", "45 minutes", "60 minutes", "Custom"],
            "defaultValue": "10 minutes"
          },
          {
            "name": "customDuration",
            "label": "Custom Duration (minutes)",
            "type": "number",
            "defaultValue": 10,
            "min": 1,
            "max": 180,
            "helpText": "Only used when 'Custom' is selected above"
          },
          {
            "name": "bellInterval",
            "label": "Bell Interval",
            "type": "select",
            "options": ["No bells", "Every 1 minute", "Every 2 minutes", "Every 5 minutes", "Start and end only", "End only"],
            "defaultValue": "Start and end only"
          },
          {
            "name": "ambientSound",
            "label": "Ambient Sound",
            "type": "select",
            "options": ["Silence", "Rain", "Ocean waves", "Forest", "White noise", "Tibetan bowl", "Soft wind"],
            "defaultValue": "Rain"
          },
          {
            "name": "bellSound",
            "label": "Bell Style",
            "type": "select",
            "options": ["Tibetan singing bowl", "Zen bell", "Soft chime", "Gong", "None"],
            "defaultValue": "Tibetan singing bowl"
          },
          {
            "name": "guidance",
            "label": "Guidance Mode",
            "type": "select",
            "options": ["Silent (no guidance)", "Breathing reminders", "Body scan prompts"],
            "defaultValue": "Breathing reminders"
          }
        ],
        "submitLabel": "Begin Session"
      },
      "position": 0
    },
    {
      "type": "timer",
      "id": "meditation-timer",
      "props": {
        "title": "Meditate",
        "mode": "countdown",
        "defaultDuration": 600,
        "displayFormat": "mm:ss",
        "showProgress": true,
        "progressStyle": "circular",
        "controls": ["start", "pause", "reset"],
        "onComplete": "play-bell",
        "ambientEnabled": true,
        "autoStartOnConfig": false,
        "inspirationalText": [
          "Breathe in slowly... breathe out slowly.",
          "Let thoughts pass like clouds.",
          "You are exactly where you need to be.",
          "Notice the breath. Return to the breath.",
          "Each exhale, release tension."
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "560px", "padding": "32px" },
  "theme": { "primaryColor": "#6ee7b7", "backgroundColor": "#ecfdf5", "fontFamily": "'Georgia', serif", "borderRadius": "20px" }
}
