{
  "title": "Project Kanban Board",
  "description": "Drag-and-drop task board to manage any project",
  "category": "productivity",
  "primitives": [
    {
      "type": "kanban-board",
      "id": "project-kanban",
      "props": {
        "title": "Project Board",
        "columns": [
          {
            "id": "backlog",
            "title": "Backlog",
            "color": "#94a3b8",
            "cards": [
              { "id": "1", "title": "Research competitors", "description": "Analyze top 5 competitors", "priority": "low", "tags": ["research"] },
              { "id": "2", "title": "Write API docs", "description": "Document all REST endpoints", "priority": "medium", "tags": ["docs"] }
            ]
          },
          {
            "id": "todo",
            "title": "To Do",
            "color": "#3b82f6",
            "cards": [
              { "id": "3", "title": "Design landing page", "description": "Hero section + features", "priority": "high", "tags": ["design"] },
              { "id": "4", "title": "Set up CI/CD", "description": "GitHub Actions pipeline", "priority": "medium", "tags": ["devops"] }
            ]
          },
          {
            "id": "in-progress",
            "title": "In Progress",
            "color": "#f59e0b",
            "cards": [
              { "id": "5", "title": "Build auth flow", "description": "OAuth + email sign-in", "priority": "high", "tags": ["backend", "auth"] }
            ]
          },
          {
            "id": "done",
            "title": "Done",
            "color": "#10b981",
            "cards": [
              { "id": "6", "title": "Project setup", "description": "Repo, deps, config", "priority": "medium", "tags": ["setup"] }
            ]
          }
        ],
        "allowDrag": true,
        "showPriority": true,
        "showTags": true
      },
      "position": 0
    }
  ],
  "layout": { "type": "full-width", "padding": "16px" },
  "theme": { "primaryColor": "#3b82f6", "backgroundColor": "#f8fafc", "fontFamily": "system-ui, sans-serif", "borderRadius": "8px" }
}