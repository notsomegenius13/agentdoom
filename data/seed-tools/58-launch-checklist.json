{
  "title": "Product Launch Checklist",
  "description": "The ultimate checklist for launching your product — don't miss a single step",
  "category": "business",
  "viralHook": "I used this checklist and hit #1 on Product Hunt. Save it.",
  "shareability": 4,
  "primitives": [
    {
      "type": "checklist",
      "id": "launch-items",
      "props": {
        "title": "Launch Day Checklist",
        "items": [
          { "label": "Landing page is live and loads in < 3 seconds", "checked": false },
          { "label": "Analytics installed (Plausible, PostHog, or GA4)", "checked": false },
          { "label": "Error tracking set up (Sentry or similar)", "checked": false },
          { "label": "Payment flow tested with real card (Stripe test mode)", "checked": false },
          { "label": "Email onboarding sequence ready (3-5 emails)", "checked": false },
          { "label": "Social media announcements drafted (Twitter, LinkedIn, Reddit)", "checked": false },
          { "label": "Product Hunt page prepared (if applicable)", "checked": false },
          { "label": "Open Graph / social preview images set", "checked": false },
          { "label": "Favicon and app icons added", "checked": false },
          { "label": "404 page is friendly, not default", "checked": false },
          { "label": "Terms of Service and Privacy Policy published", "checked": false },
          { "label": "SSL certificate active (HTTPS)", "checked": false },
          { "label": "Support email or chat widget ready", "checked": false },
          { "label": "Mobile responsive — tested on real device", "checked": false },
          { "label": "Core user flow tested by 3+ people", "checked": false },
          { "label": "Backup and recovery plan in place", "checked": false },
          { "label": "Performance tested under load", "checked": false },
          { "label": "Changelog or release notes ready", "checked": false }
        ],
        "showProgress": true
      },
      "position": 0
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "580px", "padding": "24px" },
  "theme": { "primaryColor": "#059669", "backgroundColor": "#ecfdf5", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
