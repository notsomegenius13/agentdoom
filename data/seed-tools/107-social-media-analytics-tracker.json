{
  "title": "Social Media Analytics Tracker",
  "description": "Track your follower growth and engagement across all major platforms",
  "category": "social",
  "viralHook": "Went from 500 to 5K followers in 3 months - here's how I tracked my growth!",
  "shareability": 7,
  "primitives": [
    {
      "type": "tracker",
      "id": "social-media-growth-tracker",
      "props": {
        "title": "Social Media Growth Dashboard",
        "subtitle": "Log your numbers daily and watch the magic happen",
        "trackingMode": "daily",
        "streakEnabled": true,
        "streakLabel": "Tracking Streak",
        "streakUnit": "days",
        "items": [
          {
            "id": "instagram-followers",
            "label": "Instagram Followers",
            "icon": "instagram",
            "color": "#E1306C",
            "inputType": "number",
            "placeholder": "Enter follower count",
            "targets": {
              "daily": 10,
              "weekly": 70
            },
            "unit": "followers",
            "showGrowthRate": true,
            "showDelta": true
          },
          {
            "id": "tiktok-followers",
            "label": "TikTok Followers",
            "icon": "tiktok",
            "color": "#000000",
            "inputType": "number",
            "placeholder": "Enter follower count",
            "targets": {
              "daily": 25,
              "weekly": 175
            },
            "unit": "followers",
            "showGrowthRate": true,
            "showDelta": true
          },
          {
            "id": "youtube-subscribers",
            "label": "YouTube Subscribers",
            "icon": "youtube",
            "color": "#FF0000",
            "inputType": "number",
            "placeholder": "Enter subscriber count",
            "targets": {
              "daily": 5,
              "weekly": 35
            },
            "unit": "subscribers",
            "showGrowthRate": true,
            "showDelta": true
          },
          {
            "id": "twitter-followers",
            "label": "Twitter / X Followers",
            "icon": "twitter",
            "color": "#1DA1F2",
            "inputType": "number",
            "placeholder": "Enter follower count",
            "targets": {
              "daily": 8,
              "weekly": 56
            },
            "unit": "followers",
            "showGrowthRate": true,
            "showDelta": true
          },
          {
            "id": "linkedin-connections",
            "label": "LinkedIn Connections",
            "icon": "linkedin",
            "color": "#0A66C2",
            "inputType": "number",
            "placeholder": "Enter connection count",
            "targets": {
              "daily": 5,
              "weekly": 35
            },
            "unit": "connections",
            "showGrowthRate": true,
            "showDelta": true
          }
        ],
        "summaryMetrics": [
          {
            "id": "total-audience",
            "label": "Total Audience",
            "formula": "sum(instagram-followers, tiktok-followers, youtube-subscribers, twitter-followers, linkedin-connections)",
            "format": "number"
          },
          {
            "id": "best-platform",
            "label": "Fastest Growing",
            "formula": "maxGrowth(instagram-followers, tiktok-followers, youtube-subscribers, twitter-followers, linkedin-connections)",
            "format": "label"
          },
          {
            "id": "weekly-growth",
            "label": "Weekly Growth Rate",
            "formula": "avgGrowthPercent(all, 7)",
            "format": "percent"
          }
        ],
        "milestones": [
          { "count": 100, "label": "Getting Started", "emoji": "🌱" },
          { "count": 500, "label": "Building Momentum", "emoji": "🔥" },
          { "count": 1000, "label": "1K Club", "emoji": "🎉" },
          { "count": 5000, "label": "Rising Star", "emoji": "⭐" },
          { "count": 10000, "label": "10K Influencer", "emoji": "🚀" },
          { "count": 50000, "label": "Major Player", "emoji": "👑" },
          { "count": 100000, "label": "100K Legend", "emoji": "💎" }
        ],
        "reminderTime": "21:00",
        "reminderMessage": "Time to log today's social media numbers!"
      }
    }
  ]
}