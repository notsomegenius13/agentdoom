{
  "title": "Carbon Footprint Calculator",
  "description": "Estimate your annual carbon footprint and see how you compare to global averages",
  "category": "utilities",
  "viralHook": "The average American emits 16 tons of CO2/year. The world average is 4. What's yours?",
  "shareability": 4,
  "primitives": [
    {
      "type": "calculator",
      "id": "carbon-calc",
      "props": {
        "title": "Your Annual Carbon Footprint",
        "inputs": [
          { "name": "carMiles", "label": "Car Miles/Year", "type": "number", "defaultValue": 12000, "min": 0, "step": 500 },
          { "name": "flights", "label": "Round-Trip Flights/Year", "type": "number", "defaultValue": 4, "min": 0, "max": 50 },
          { "name": "electricBill", "label": "Monthly Electric Bill ($)", "type": "number", "defaultValue": 120, "min": 0, "step": 10 },
          { "name": "gasBill", "label": "Monthly Gas/Heating Bill ($)", "type": "number", "defaultValue": 60, "min": 0, "step": 10 },
          { "name": "meatMeals", "label": "Meat Meals Per Week", "type": "number", "defaultValue": 10, "min": 0, "max": 21 }
        ],
        "formula": "(carMiles * 0.000404) + (flights * 1.6) + (electricBill * 12 * 0.005) + (gasBill * 12 * 0.012) + (meatMeals * 52 * 0.006)",
        "resultLabel": "Annual CO₂ Emissions",
        "resultPrefix": "",
        "resultSuffix": " tons"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "carbon-compare",
      "props": {
        "title": "How You Compare",
        "stats": [
          { "label": "Your Footprint", "value": "~14 tons", "change": 0, "changeLabel": "CO₂ per year", "icon": "trending" },
          { "label": "US Average", "value": "16 tons", "change": 0, "changeLabel": "per person/year", "icon": "percent" },
          { "label": "World Average", "value": "4 tons", "change": 0, "changeLabel": "per person/year", "icon": "dollar" },
          { "label": "Paris Target", "value": "2.1 tons", "change": 0, "changeLabel": "by 2050", "icon": "cart" }
        ],
        "charts": [
          {
            "type": "bar",
            "title": "CO₂ by Country (tons/person/year)",
            "data": [
              { "label": "Qatar", "value": 37 },
              { "label": "USA", "value": 16 },
              { "label": "China", "value": 8 },
              { "label": "UK", "value": 5 },
              { "label": "India", "value": 2 }
            ]
          }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "560px", "padding": "24px" },
  "theme": { "primaryColor": "#059669", "backgroundColor": "#ecfdf5", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
