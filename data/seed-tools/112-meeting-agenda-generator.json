{
  "title": "Meeting Agenda Generator",
  "description": "Generate structured meeting agendas with topics, timing, and action items",
  "category": "productivity",
  "viralHook": "No agenda, no meeting. Generate yours in 30 seconds.",
  "shareability": 5,
  "primitives": [
    {
      "type": "form",
      "id": "meeting-agenda-form",
      "props": {
        "fields": [
          {
            "name": "meetingTitle",
            "label": "Meeting Title",
            "type": "text",
            "placeholder": "e.g., Q2 Sprint Planning",
            "required": true
          },
          {
            "name": "meetingDate",
            "label": "Date",
            "type": "date",
            "required": true
          },
          {
            "name": "duration",
            "label": "Duration",
            "type": "select",
            "required": true,
            "options": [
              { "label": "15 minutes", "value": "15" },
              { "label": "30 minutes", "value": "30" },
              { "label": "45 minutes", "value": "45" },
              { "label": "60 minutes", "value": "60" }
            ]
          },
          {
            "name": "attendees",
            "label": "Attendees",
            "type": "textarea",
            "placeholder": "One attendee per line\ne.g.,\nAlice Chen (Product)\nBob Smith (Engineering)\nCarol Davis (Design)",
            "required": true
          },
          {
            "name": "topics",
            "label": "Discussion Topics",
            "type": "textarea",
            "placeholder": "One topic per line\ne.g.,\nSprint velocity review\nUpcoming feature priorities\nBlockers and risks",
            "required": true
          },
          {
            "name": "previousActions",
            "label": "Action Items from Last Meeting",
            "type": "textarea",
            "placeholder": "One action item per line\ne.g.,\nAlice: Finalize wireframes for dashboard\nBob: Deploy staging fix for auth bug",
            "required": false
          }
        ],
        "submitLabel": "Generate Agenda",
        "output": {
          "type": "textarea",
          "readonly": true,
          "copyButton": true,
          "template": "========================================\n MEETING AGENDA\n========================================\n\nTitle:    {{meetingTitle}}\nDate:     {{meetingDate}}\nDuration: {{duration}} minutes\n\n----------------------------------------\nATTENDEES\n----------------------------------------\n{{attendees}}\n\n----------------------------------------\nPREVIOUS ACTION ITEMS (Review)\n----------------------------------------\n{{previousActions}}\n\n----------------------------------------\nDISCUSSION TOPICS\n----------------------------------------\n{{topics}}\n\n----------------------------------------\nNEW ACTION ITEMS\n----------------------------------------\n[ ] \n[ ] \n[ ] \n\n----------------------------------------\nNEXT MEETING\n----------------------------------------\nDate: TBD\nTime: TBD\n\n========================================"
        }
      }
    }
  ]
}
