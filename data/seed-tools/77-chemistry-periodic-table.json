{
  "title": "Interactive Periodic Table",
  "description": "Searchable periodic table with element details, atomic data, and category filters — noble gases, alkali metals, and more",
  "category": "education",
  "viralHook": "Only 94 elements occur naturally — can you name 10?",
  "shareability": 3,
  "primitives": [
    {
      "type": "form",
      "id": "element-filter",
      "props": {
        "title": "Search the Periodic Table",
        "submitLabel": "Filter Elements",
        "fields": [
          {
            "name": "searchQuery",
            "label": "Search by Name or Symbol",
            "type": "text",
            "placeholder": "e.g. Oxygen, Fe, Carbon..."
          },
          {
            "name": "category",
            "label": "Element Category",
            "type": "select",
            "options": [
              "All Categories",
              "Alkali Metals",
              "Alkaline Earth Metals",
              "Transition Metals",
              "Post-Transition Metals",
              "Metalloids",
              "Nonmetals",
              "Halogens",
              "Noble Gases",
              "Lanthanides",
              "Actinides"
            ],
            "defaultValue": "All Categories"
          },
          {
            "name": "state",
            "label": "State at Room Temperature",
            "type": "select",
            "options": ["All States", "Solid", "Liquid", "Gas"],
            "defaultValue": "All States"
          },
          {
            "name": "sortBy",
            "label": "Sort By",
            "type": "select",
            "options": ["Atomic Number", "Alphabetical", "Atomic Mass"],
            "defaultValue": "Atomic Number"
          }
        ]
      },
      "position": 0
    },
    {
      "type": "table",
      "id": "periodic-table-data",
      "props": {
        "title": "Elements",
        "searchable": true,
        "sortable": true,
        "columns": [
          { "key": "number", "label": "#", "width": "50px" },
          { "key": "symbol", "label": "Symbol", "width": "70px", "bold": true },
          { "key": "name", "label": "Element Name", "width": "160px" },
          { "key": "atomicMass", "label": "Atomic Mass", "width": "120px" },
          { "key": "category", "label": "Category", "width": "200px" },
          { "key": "state", "label": "State (25°C)", "width": "100px" },
          { "key": "electrons", "label": "Electrons", "width": "90px" },
          { "key": "discovery", "label": "Discovered", "width": "100px" }
        ],
        "rows": [
