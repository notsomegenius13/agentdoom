{
  "title": "Fitness Journey Tracker",
  "description": "Track workouts, monitor weight progress, manage nutrition goals, and log exercises — your complete fitness dashboard",
  "category": "health",
  "primitives": [
    {
      "type": "stats-dashboard",
      "id": "fitness-overview",
      "props": {
        "title": "Fitness Overview",
        "stats": [
          { "label": "Current Weight", "value": "175 lbs", "change": -3.2, "changeLabel": "vs last month", "icon": "trending" },
          { "label": "Workouts This Week", "value": "4 / 5", "change": 1, "changeLabel": "more than last week", "icon": "cart" },
          { "label": "Calories Today", "value": "1,850", "change": -150, "changeLabel": "under target", "icon": "dollar" },
          { "label": "Streak", "value": "18 days", "change": 5, "changeLabel": "longer than avg", "icon": "trending" }
        ],
        "charts": []
      },
      "position": 0
    },
    {
      "type": "tracker",
      "id": "todays-workout",
      "props": {
        "title": "Today's Workout — Upper Body",
        "items": [
          { "name": "Bench Press — 3×10 @ 155 lbs", "icon": "🏋️", "target": 3 },
          { "name": "Squats — 3×8 @ 205 lbs", "icon": "🦵", "target": 3 },
          { "name": "Deadlifts — 3×5 @ 245 lbs", "icon": "💪", "target": 3 },
          { "name": "Pull-ups — 3×8 bodyweight", "icon": "🧗", "target": 3 },
          { "name": "Planks — 3×60 seconds", "icon": "🧘", "target": 3 }
        ],
        "period": "daily",
        "showStreak": true
      },
      "position": 1
    },
    {
      "type": "chart",
      "id": "weight-progress",
      "props": {
        "title": "Weight Progress",
        "chartType": "line",
        "data": [
          { "label": "Week 1", "value": 185 },
          { "label": "Week 2", "value": 183.5 },
          { "label": "Week 3", "value": 182 },
          { "label": "Week 4", "value": 181 },
          { "label": "Week 5", "value": 179.5 },
          { "label": "Week 6", "value": 178 },
          { "label": "Week 7", "value": 176.5 },
          { "label": "Week 8", "value": 175 }
        ],
        "xLabel": "Week",
        "yLabel": "Weight (lbs)"
      },
      "position": 2
    },
    {
      "type": "checklist",
      "id": "nutrition-checklist",
      "props": {
        "title": "Nutrition Checklist",
        "categories": [
          {
            "name": "Daily Nutrition Goals",
            "items": [
              "Hit protein target — 150g minimum",
              "Drink 3L of water throughout the day",
              "Eat 5 servings of vegetables",
              "Take daily vitamins (D3, Omega-3, Magnesium)",
              "No sugar after 6 PM"
            ]
          }
        ],
        "showProgress": true
      },
      "position": 3
    },
    {
      "type": "form",
      "id": "log-workout",
      "props": {
        "title": "Log Workout",
        "fields": [
          { "name": "exercise", "label": "Exercise", "type": "select", "options": ["Bench Press", "Squats", "Deadlifts", "Pull-ups", "Shoulder Press", "Barbell Rows", "Lunges", "Planks", "Bicep Curls", "Tricep Dips"], "required": true },
          { "name": "sets", "label": "Sets", "type": "number", "required": true },
          { "name": "reps", "label": "Reps", "type": "number", "required": true },
          { "name": "weight", "label": "Weight (lbs)", "type": "number", "required": true },
          { "name": "notes", "label": "Notes", "type": "textarea", "placeholder": "How did it feel? Any PRs?" }
        ],
        "submitLabel": "Log Exercise",
        "successMessage": "Exercise logged! Keep pushing!"
      },
      "position": 4
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "900px", "padding": "24px" },
  "theme": { "primaryColor": "#ef4444", "backgroundColor": "#fef2f2", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}