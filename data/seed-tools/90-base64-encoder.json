{
  "title": "Base64 Encoder / Decoder",
  "description": "Instantly encode or decode Base64 strings — clean, fast, and works offline",
  "category": "dev-tools",
  "viralHook": "Stop opening random Base64 sites that log your data — this one runs entirely in your browser",
  "shareability": 4,
  "primitives": [
    {
      "type": "form",
      "id": "base64-tool",
      "props": {
        "title": "Base64 Encoder / Decoder",
        "fields": [
          {
            "name": "mode",
            "label": "Operation",
            "type": "toggle",
            "options": [
              { "value": "encode", "label": "Encode → Base64" },
              { "value": "decode", "label": "Decode → Plain Text" }
            ],
            "defaultValue": "encode"
          },
          {
            "name": "inputCharset",
            "label": "Input Encoding",
            "type": "select",
            "options": ["UTF-8", "ASCII", "Latin-1"],
            "defaultValue": "UTF-8"
          },
          {
            "name": "input",
            "label": "Input",
            "type": "textarea",
            "placeholder": "Paste your text or Base64 string here...",
            "rows": 6,
            "monospace": true,
            "autofocus": true,
            "liveProcess": true
          },
          {
            "name": "output",
            "label": "Output",
            "type": "textarea",
            "placeholder": "Result will appear here...",
            "rows": 6,
            "monospace": true,
            "readonly": true,
            "copyable": true
          },
          {
            "name": "urlSafe",
            "label": "URL-safe Base64 (replace + with - and / with _)",
            "type": "checkbox",
            "defaultValue": false
          },
          {
            "name": "wrapLines",
            "label": "Wrap output at 76 characters (MIME standard)",
            "type": "checkbox",
            "defaultValue": false
          }
        ],
        "submitLabel": "Convert",
        "liveProcess": true,
        "showCharCount": true,
        "actions": [
          { "label": "Copy Output", "action": "copy", "target": "output" },
          { "label": "Swap Input / Output", "action": "swap" },
          { "label": "Clear", "action": "clear" }
        ]
      },
      "position": 0
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "680px", "padding": "24px" },
  "theme": { "primaryColor": "#22d3ee", "backgroundColor": "#0d1117", "fontFamily": "'JetBrains Mono', 'Fira Code', monospace", "borderRadius": "8px" }
}
