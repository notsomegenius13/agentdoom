{
  "title": "Global Mood Map",
  "description": "Pin your mood on the world map and see how everyone else is feeling today",
  "category": "fun",
  "viralHook": "What did you get? Share your mood pin with friends",
  "shareability": 5,
  "primitives": [
    {
      "type": "form",
      "id": "mood-submit",
      "props": {
        "title": "How Are You Feeling?",
        "fields": [
          { "name": "mood", "label": "Your Mood", "type": "select", "options": ["😊 Happy", "😢 Sad", "😤 Frustrated", "😴 Tired", "🤩 Excited", "😰 Anxious", "😌 Calm", "🤔 Thoughtful", "😂 Amused", "💪 Motivated"], "required": true },
          { "name": "region", "label": "Your Region", "type": "select", "options": ["North America", "South America", "Europe", "Africa", "Middle East", "South Asia", "East Asia", "Southeast Asia", "Oceania"], "required": true },
          { "name": "reason", "label": "One word for why?", "type": "text", "placeholder": "e.g., coffee, deadline, sunshine" }
        ],
        "submitLabel": "Pin My Mood",
        "successMessage": "Mood pinned! 📍"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "mood-stats",
      "props": {
        "title": "Global Mood Right Now",
        "stats": [
          { "label": "Happiest Region", "value": "Oceania", "change": 0, "changeLabel": "72% positive moods", "icon": "trending" },
          { "label": "Most Active", "value": "Europe", "change": 0, "changeLabel": "2,431 pins today", "icon": "cart" },
          { "label": "Top Mood", "value": "😊 Happy", "change": 0, "changeLabel": "34% of all pins", "icon": "percent" },
          { "label": "Total Pins Today", "value": "8,294", "change": 12, "changeLabel": "vs yesterday", "icon": "trending" }
        ],
        "charts": [
          {
            "type": "bar",
            "title": "Mood Distribution Today",
            "data": [
              { "label": "Happy", "value": 34 },
              { "label": "Tired", "value": 18 },
              { "label": "Calm", "value": 14 },
              { "label": "Motivated", "value": 12 },
              { "label": "Anxious", "value": 9 },
              { "label": "Excited", "value": 8 },
              { "label": "Other", "value": 5 }
            ]
          }
        ]
      },
      "position": 1
    },
    {
      "type": "poll",
      "id": "mood-poll",
      "props": {
        "title": "Quick Poll: What Drives Your Mood Today?",
        "question": "Biggest mood driver right now?",
        "options": [
          { "label": "Weather", "votes": 847 },
          { "label": "Work/School", "votes": 1203 },
          { "label": "Relationships", "votes": 634 },
          { "label": "Money", "votes": 891 },
          { "label": "Health", "votes": 412 },
          { "label": "World Events", "votes": 729 }
        ],
        "allowMultiple": false,
        "showResults": true
      },
      "position": 2
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "640px", "padding": "24px" },
  "theme": { "primaryColor": "#f59e0b", "backgroundColor": "#fffbeb", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
