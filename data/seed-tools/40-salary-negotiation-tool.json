{
  "title": "Developer Salary Negotiation Tool",
  "description": "Know your worth — calculate what you should really be earning as a developer",
  "category": "money",
  "viralHook": "Are you underpaid? Most devs are. Check your number.",
  "shareability": 5,
  "primitives": [
    {
      "type": "form",
      "id": "salary-inputs",
      "props": {
        "title": "Your Developer Profile",
        "fields": [
          { "name": "experience", "label": "Years of Experience", "type": "number", "defaultValue": 5, "min": 0, "max": 40 },
          { "name": "role", "label": "Role", "type": "select", "options": ["Junior Developer", "Mid-Level Developer", "Senior Developer", "Staff Engineer", "Principal Engineer", "Engineering Manager", "VP Engineering", "CTO"] },
          { "name": "location", "label": "Location", "type": "select", "options": ["SF Bay Area", "NYC", "Seattle", "Austin", "Denver", "Chicago", "Remote (US)", "London", "Berlin", "Toronto", "Other US City", "Other International"] },
          { "name": "specialty", "label": "Specialty", "type": "select", "options": ["Frontend", "Backend", "Full-Stack", "Mobile", "DevOps/SRE", "ML/AI", "Data Engineering", "Security", "Blockchain/Web3"] },
          { "name": "companySize", "label": "Company Size", "type": "select", "options": ["Startup (1-50)", "Growth (51-200)", "Mid-Market (201-1000)", "Enterprise (1000-5000)", "Big Tech (5000+)"] }
        ],
        "submitLabel": "Calculate My Worth"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "salary-results",
      "props": {
        "title": "Your Market Rate (Senior Dev, SF Bay Area)",
        "stats": [
          { "label": "Base Salary", "value": "$185,000", "change": 12, "changeLabel": "vs national avg", "icon": "dollar" },
          { "label": "Total Comp (w/ equity)", "value": "$275,000", "change": 35, "changeLabel": "Big Tech median", "icon": "trending" },
          { "label": "Market Percentile", "value": "75th", "change": 0, "changeLabel": "for your profile", "icon": "percent" },
          { "label": "Negotiation Leverage", "value": "High", "change": 0, "changeLabel": "demand > supply", "icon": "cart" }
        ]
      },
      "position": 1
    },
    {
      "type": "table",
      "id": "comp-breakdown",
      "props": {
        "title": "Compensation Benchmarks by Level",
        "columns": [
          { "key": "level", "label": "Level", "sortable": true },
          { "key": "base", "label": "Base Salary", "sortable": true },
          { "key": "totalComp", "label": "Total Comp", "sortable": true },
          { "key": "demand", "label": "Market Demand", "sortable": false }
        ],
        "data": [
          { "level": "Junior (0-2 yrs)", "base": "$90-120K", "totalComp": "$100-140K", "demand": "Moderate" },
          { "level": "Mid (3-5 yrs)", "base": "$130-165K", "totalComp": "$150-200K", "demand": "High" },
          { "level": "Senior (5-8 yrs)", "base": "$165-210K", "totalComp": "$200-300K", "demand": "Very High" },
          { "level": "Staff (8-12 yrs)", "base": "$200-260K", "totalComp": "$300-450K", "demand": "Very High" },
          { "level": "Principal (12+ yrs)", "base": "$250-350K", "totalComp": "$400-700K", "demand": "Extreme" }
        ],
        "showSearch": false,
        "pageSize": 10
      },
      "position": 2
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "620px", "padding": "24px" },
  "theme": { "primaryColor": "#059669", "backgroundColor": "#ecfdf5", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
