          {
            "id": "rock",
            "title": "Rock",
            "icon": "✊",
            "description": "Crushes Scissors",
            "action": "Choose Rock",
            "selectable": true
          },
          {
            "id": "paper",
            "title": "Paper",
            "icon": "✋",
            "description": "Covers Rock",
            "action": "Choose Paper",
            "selectable": true
          },
          {
            "id": "scissors",
            "title": "Scissors",
            "icon": "✌️",
            "description": "Cuts Paper",
            "action": "Choose Scissors",
            "selectable": true
          }
        ],
        "selectionMode": "single",
        "submitLabel": "Fight!"
      },
      "position": 0
    },
    {
