          { "label": "Losses", "value": "0", "trend": "down", "trendValue": "Loss streak: 0" },
          { "label": "Draws", "value": "0", "trend": "neutral", "trendValue": "Total games: 0" },
          { "label": "Win Rate", "value": "0%", "trend": "neutral", "trendValue": "vs CPU average 50%" }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "640px", "padding": "24px" },
  "theme": { "primaryColor": "#f59e0b", "backgroundColor": "#1e1b4b", "fontFamily": "'Inter', sans-serif", "borderRadius": "16px" }
