{
  "title": "Influencer Rate Calculator",
  "description": "How much should you charge for sponsored posts? Calculate your rate based on followers and engagement",
  "category": "creator",
  "viralHook": "10K followers with 5% engagement = $250/post minimum. Stop undercharging.",
  "shareability": 5,
  "primitives": [
    {
      "type": "calculator",
      "id": "influencer-rate",
      "props": {
        "title": "Know Your Rate",
        "inputs": [
          { "name": "followers", "label": "Total Followers", "type": "number", "defaultValue": 25000, "min": 100, "step": 1000 },
          { "name": "engagementRate", "label": "Engagement Rate (%)", "type": "number", "defaultValue": 4.5, "min": 0.1, "max": 30, "step": 0.1 },
          { "name": "platform", "label": "Primary Platform CPM ($)", "type": "number", "defaultValue": 15, "min": 1, "max": 100, "step": 1 },
          { "name": "nicheMultiplier", "label": "Niche Premium (1-3x)", "type": "number", "defaultValue": 1.5, "min": 1, "max": 3, "step": 0.1 }
        ],
        "formula": "(followers * (engagementRate / 100) * platform * nicheMultiplier) / 1000 * 10",
        "resultLabel": "Suggested Rate Per Post",
        "resultPrefix": "$",
        "resultSuffix": ""
      },
      "position": 0
    },
    {
      "type": "table",
      "id": "rate-guide",
      "props": {
        "title": "Industry Rate Guide",
        "columns": [
          { "key": "tier", "label": "Tier", "sortable": false },
          { "key": "followers", "label": "Followers", "sortable": false },
          { "key": "instagram", "label": "Instagram Post", "sortable": true },
          { "key": "tiktok", "label": "TikTok Video", "sortable": true },
          { "key": "youtube", "label": "YouTube Video", "sortable": true }
        ],
        "data": [
          { "tier": "Nano", "followers": "1K-10K", "instagram": "$50-250", "tiktok": "$25-150", "youtube": "$100-500" },
          { "tier": "Micro", "followers": "10K-50K", "instagram": "$250-1K", "tiktok": "$150-750", "youtube": "$500-2.5K" },
          { "tier": "Mid", "followers": "50K-500K", "instagram": "$1K-5K", "tiktok": "$750-3K", "youtube": "$2.5K-10K" },
          { "tier": "Macro", "followers": "500K-1M", "instagram": "$5K-15K", "tiktok": "$3K-10K", "youtube": "$10K-30K" },
          { "tier": "Mega", "followers": "1M+", "instagram": "$15K-100K+", "tiktok": "$10K-50K+", "youtube": "$30K-100K+" }
        ],
        "showSearch": false,
        "pageSize": 10
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "600px", "padding": "24px" },
  "theme": { "primaryColor": "#e11d48", "backgroundColor": "#fff1f2", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
