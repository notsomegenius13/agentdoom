{
  "title": "Essay Word Counter",
  "description": "Paste your essay or text and instantly see word count, reading time, paragraph count, sentence count, and character count",
  "category": "education",
  "viralHook": "Pasted my essay and found out it was 200 words short with 5 minutes to deadline — saved me",
  "shareability": 3,
  "primitives": [
    {
      "type": "form",
      "id": "text-input",
      "props": {
        "title": "Paste Your Text",
        "submitLabel": "Analyze Text",
        "fields": [
          {
            "id": "essay_text",
            "label": "Your Essay or Text",
            "type": "textarea",
            "placeholder": "Paste your essay, article, or any text here...",
            "required": true,
            "rows": 14
          },
          {
            "id": "reading_speed",
            "label": "Reading Speed",
            "type": "select",
            "options": [
              { "value": "150", "label": "Slow Reader (150 wpm)" },
              { "value": "200", "label": "Average Reader (200 wpm)" },
              { "value": "250", "label": "Fast Reader (250 wpm)" },
              { "value": "300", "label": "Speed Reader (300 wpm)" }
            ],
            "defaultValue": "200"
          }
        ]
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "text-stats",
      "props": {
        "title": "Text Analysis",
        "stats": [
          {
            "id": "word-count",
            "label": "Word Count",
            "value": "0",
            "icon": "type",
            "color": "#6366f1",
            "description": "Total words in your text"
          },
          {
            "id": "reading-time",
            "label": "Reading Time",
            "value": "0 min",
            "icon": "clock",
            "color": "#f59e0b",
            "description": "Estimated time to read"
          },
          {
            "id": "paragraph-count",
            "label": "Paragraphs",
            "value": "0",
            "icon": "align-left",
            "color": "#10b981",
            "description": "Number of paragraphs"
          },
          {
            "id": "sentence-count",
            "label": "Sentences",
            "value": "0",
            "icon": "minus",
            "color": "#ec4899",
            "description": "Number of sentences"
          },
          {
            "id": "character-count",
            "label": "Characters (with spaces)",
            "value": "0",
            "icon": "hash",
            "color": "#06b6d4",
            "description": "Total character count"
          },
          {
            "id": "character-no-spaces",
            "label": "Characters (no spaces)",
            "value": "0",
            "icon": "hash",
            "color": "#8b5cf6",
            "description": "Characters excluding spaces"
          }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "700px", "padding": "24px" },
  "theme": { "primaryColor": "#6366f1", "backgroundColor": "#f5f3ff", "fontFamily": "'Inter', sans-serif", "borderRadius": "12px" }
}
