{
  "title": "Spotify Wrapped Stats Maker",
  "description": "Create your own Wrapped-style stats card for anything — music, coding, reading, gym",
  "category": "fun",
  "viralHook": "Make a Wrapped for literally anything. My 'GitHub Wrapped' went viral.",
  "shareability": 5,
  "primitives": [
    {
      "type": "form",
      "id": "wrapped-inputs",
      "props": {
        "title": "Create Your Wrapped",
        "fields": [
          { "name": "topic", "label": "Wrapped Topic", "type": "select", "options": ["GitHub Wrapped", "Coffee Wrapped", "Netflix Wrapped", "Gym Wrapped", "Reading Wrapped", "Travel Wrapped", "Dating App Wrapped", "Custom"] },
          { "name": "stat1Label", "label": "Top Stat Label", "type": "text", "placeholder": "e.g., Total Commits" },
          { "name": "stat1Value", "label": "Top Stat Value", "type": "text", "placeholder": "e.g., 2,847" },
          { "name": "stat2Label", "label": "Second Stat Label", "type": "text", "placeholder": "e.g., Longest Streak" },
          { "name": "stat2Value", "label": "Second Stat Value", "type": "text", "placeholder": "e.g., 47 days" },
          { "name": "stat3Label", "label": "Third Stat Label", "type": "text", "placeholder": "e.g., Top Language" },
          { "name": "stat3Value", "label": "Third Stat Value", "type": "text", "placeholder": "e.g., TypeScript" },
          { "name": "personality", "label": "Your Personality Type", "type": "text", "placeholder": "e.g., The Night Owl Shipper" }
        ],
        "submitLabel": "Generate Wrapped"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "wrapped-preview",
      "props": {
        "title": "Your 2024 GitHub Wrapped",
        "stats": [
          { "label": "Total Commits", "value": "2,847", "change": 34, "changeLabel": "vs last year", "icon": "trending" },
          { "label": "Longest Streak", "value": "47 days", "change": 0, "changeLabel": "Jun 3 — Jul 19", "icon": "percent" },
          { "label": "Top Language", "value": "TypeScript", "change": 0, "changeLabel": "68% of your code", "icon": "dollar" },
          { "label": "Personality", "value": "Night Owl", "change": 0, "changeLabel": "73% of commits after 10pm", "icon": "cart" }
        ],
        "charts": [
          {
            "type": "bar",
            "title": "Commits by Day of Week",
            "data": [
              { "label": "Mon", "value": 380 },
              { "label": "Tue", "value": 520 },
              { "label": "Wed", "value": 470 },
              { "label": "Thu", "value": 410 },
              { "label": "Fri", "value": 340 },
              { "label": "Sat", "value": 380 },
              { "label": "Sun", "value": 347 }
            ]
          }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "580px", "padding": "24px" },
  "theme": { "primaryColor": "#1db954", "backgroundColor": "#111827", "fontFamily": "system-ui, sans-serif", "borderRadius": "16px" }
}
