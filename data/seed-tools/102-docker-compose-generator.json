{
  "title": "Docker Compose Generator",
  "description": "Generate docker-compose.yml service snippets from a simple form",
  "category": "dev-tools",
  "viralHook": "Generate docker-compose configs without memorizing the YAML spec",
  "shareability": 5,
  "primitives": [
    {
      "type": "form",
      "id": "docker-compose-form",
      "props": {
        "title": "Docker Compose Service Generator",
        "description": "Fill in your service details and get a ready-to-use docker-compose.yml snippet.",
        "submitLabel": "Generate docker-compose.yml",
        "fields": [
          {
            "id": "service_name",
            "label": "Service Name",
            "type": "text",
            "placeholder": "my-api",
            "required": true,
            "helperText": "Lowercase name for the service (e.g., web, api, db)"
          },
          {
            "id": "image",
            "label": "Docker Image",
            "type": "text",
            "placeholder": "node:20-alpine",
            "required": true,
            "helperText": "Image name and tag from Docker Hub or your registry"
          },
          {
            "id": "ports",
            "label": "Port Mappings",
            "type": "text",
            "placeholder": "3000:3000, 9229:9229",
            "required": false,
            "helperText": "Comma-separated host:container port pairs"
          },
          {
            "id": "volumes",
            "label": "Volume Mounts",
            "type": "text",
            "placeholder": "./src:/app/src, ./data:/app/data",
            "required": false,
            "helperText": "Comma-separated host:container volume paths"
          },
          {
            "id": "env_vars",
            "label": "Environment Variables",
            "type": "textarea",
            "placeholder": "NODE_ENV=production\nDATABASE_URL=postgres://user:pass@db:5432/mydb\nREDIS_URL=redis://cache:6379",
            "required": false,
            "rows": 5,
            "helperText": "One KEY=VALUE per line"
          },
          {
            "id": "depends_on",
            "label": "Depends On",
            "type": "text",
            "placeholder": "db, cache, redis",
            "required": false,
            "helperText": "Comma-separated list of services this depends on"
          },
          {
            "id": "restart_policy",
            "label": "Restart Policy",
            "type": "select",
            "options": [
              { "label": "no", "value": "no" },
              { "label": "always", "value": "always" },
              { "label": "on-failure", "value": "on-failure" },
              { "label": "unless-stopped", "value": "unless-stopped" }
            ],
            "defaultValue": "unless-stopped",
            "helperText": "When the container should automatically restart"
          },
          {
            "id": "network",
            "label": "Network Name",
            "type": "text",
            "placeholder": "app-network",
            "required": false,
            "helperText": "Custom Docker network to attach this service to"
          }
        ],
        "output": {
          "id": "compose_output",
          "label": "Generated docker-compose.yml",
          "type": "textarea",
          "readonly": true,
          "rows": 20,
          "copyButton": true,
          "language": "yaml",
          "transform": "dockerComposeYaml"
        }
      }
    }
  ]
}
