{
  "title": "Event Planner",
  "description": "Manage your guest list, track tasks, monitor the budget, and keep everything on schedule",
  "category": "productivity",
  "primitives": [
    {
      "type": "stats-dashboard",
      "id": "event-overview",
      "props": {
        "title": "Event Overview — Summer Launch Party",
        "stats": [
          { "label": "Guests Confirmed", "value": "68 / 100", "change": 12, "changeLabel": "this week", "icon": "cart" },
          { "label": "Budget Used", "value": "$4,200", "change": -5.2, "changeLabel": "under budget", "icon": "dollar" },
          { "label": "Tasks Done", "value": "18 / 25", "change": 72, "changeLabel": "percent", "icon": "percent" },
          { "label": "Days Until Event", "value": "14", "change": 0, "changeLabel": "", "icon": "trending" }
        ],
        "charts": []
      },
      "position": 0
    },
    {
      "type": "table",
      "id": "guest-list",
      "props": {
        "title": "Guest List",
        "columns": [
          { "key": "name", "label": "Name", "sortable": true },
          { "key": "email", "label": "Email", "sortable": false },
          { "key": "rsvp", "label": "RSVP", "sortable": true },
          { "key": "dietary", "label": "Dietary", "sortable": true },
          { "key": "plusOne", "label": "+1", "sortable": true }
        ],
        "data": [
          { "name": "Alex Rivera", "email": "alex@email.com", "rsvp": "✅ Yes", "dietary": "None", "plusOne": "Yes" },
          { "name": "Jordan Lee", "email": "jordan@email.com", "rsvp": "✅ Yes", "dietary": "Vegetarian", "plusOne": "No" },
          { "name": "Sam Patel", "email": "sam@email.com", "rsvp": "⏳ Pending", "dietary": "Vegan", "plusOne": "Yes" },
          { "name": "Casey Kim", "email": "casey@email.com", "rsvp": "✅ Yes", "dietary": "Gluten-free", "plusOne": "No" },
          { "name": "Morgan Chen", "email": "morgan@email.com", "rsvp": "❌ No", "dietary": "—", "plusOne": "—" },
          { "name": "Taylor Nguyen", "email": "taylor@email.com", "rsvp": "✅ Yes", "dietary": "None", "plusOne": "Yes" }
        ],
        "showSearch": true,
        "pageSize": 10
      },
      "position": 1
    },
    {
      "type": "checklist",
      "id": "event-tasks",
      "props": {
        "title": "Event Checklist",
        "categories": [
          { "name": "Venue & Setup", "items": ["Book venue", "Arrange tables & seating chart", "Order decorations", "Set up AV equipment", "Arrange parking/valet"] },
          { "name": "Food & Drinks", "items": ["Confirm caterer", "Finalize menu (include dietary options)", "Order bar supplies", "Arrange cake/dessert", "Plan serving timeline"] },
          { "name": "Logistics", "items": ["Send invitations", "Follow up on RSVPs", "Hire photographer", "Create event playlist", "Arrange transportation for VIPs"] },
          { "name": "Day-of", "items": ["Final venue walkthrough", "Brief event staff", "Set up check-in table", "Test microphone/speakers", "Final headcount to caterer"] }
        ],
        "showProgress": true
      },
      "position": 2
    },
    {
      "type": "form",
      "id": "add-guest",
      "props": {
        "title": "Add Guest",
        "fields": [
          { "name": "name", "label": "Full Name", "type": "text", "required": true, "placeholder": "Jane Smith" },
          { "name": "email", "label": "Email", "type": "email", "required": true, "placeholder": "jane@email.com" },
          { "name": "dietary", "label": "Dietary Restrictions", "type": "select", "options": ["None", "Vegetarian", "Vegan", "Gluten-free", "Halal", "Kosher", "Other"] },
          { "name": "plusOne", "label": "Plus One?", "type": "select", "options": ["No", "Yes"] },
          { "name": "notes", "label": "Notes", "type": "textarea", "placeholder": "Seating preferences, allergies, etc." }
        ],
        "submitLabel": "Add to Guest List",
        "successMessage": "Guest added!"
      },
      "position": 3
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "900px", "padding": "24px" },
  "theme": { "primaryColor": "#d946ef", "backgroundColor": "#fdf4ff", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
