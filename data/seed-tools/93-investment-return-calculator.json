{
  "title": "Investment Return Calculator",
  "description": "Calculate your projected investment returns with compound growth and monthly contributions",
  "category": "finance",
  "viralHook": "Investing $500/month at 10% turns into HOW much?! Run the numbers yourself",
  "shareability": 5,
  "primitives": [
    {
      "type": "calculator",
      "id": "investment-calc",
      "props": {
        "title": "Investment Growth Projector",
        "fields": [
          { "name": "initialInvestment", "label": "Initial Investment ($)", "type": "number", "defaultValue": 5000, "min": 0, "prefix": "$" },
          { "name": "monthlyContribution", "label": "Monthly Contribution ($)", "type": "number", "defaultValue": 500, "min": 0, "prefix": "$" },
          { "name": "annualReturn", "label": "Expected Annual Return (%)", "type": "number", "defaultValue": 10, "min": 0, "max": 50, "suffix": "%", "step": 0.5 },
          { "name": "years", "label": "Investment Timeline (Years)", "type": "number", "defaultValue": 25, "min": 1, "max": 60 },
          { "name": "compounding", "label": "Compounding Frequency", "type": "select", "options": ["Monthly", "Quarterly", "Annually"], "defaultValue": "Monthly" }
        ],
        "submitLabel": "Calculate Returns",
        "results": [
          { "label": "Final Portfolio Value", "key": "finalValue", "format": "currency" },
          { "label": "Total Contributions", "key": "totalContributions", "format": "currency" },
          { "label": "Total Investment Growth", "key": "totalGrowth", "format": "currency" },
          { "label": "Return on Investment", "key": "roi", "format": "percent" },
          { "label": "Effective Annual Return", "key": "effectiveReturn", "format": "percent" }
        ]
      },
      "position": 0
    },
    {
      "type": "table",
      "id": "investment-milestones",
      "props": {
        "title": "Growth Milestones",
        "columns": [
          { "key": "year", "label": "Year", "align": "center" },
          { "key": "contributions", "label": "Total Contributed", "align": "right", "format": "currency" },
          { "key": "growth", "label": "Investment Growth", "align": "right", "format": "currency" },
          { "key": "balance", "label": "Portfolio Value", "align": "right", "format": "currency" }
        ],
        "rows": [
          { "year": 1, "contributions": "$11,000", "growth": "$867", "balance": "$11,867" },
          { "year": 5, "contributions": "$35,000", "growth": "$11,616", "balance": "$46,616" },
          { "year": 10, "contributions": "$65,000", "growth": "$43,031", "balance": "$108,031" },
          { "year": 15, "contributions": "$95,000", "growth": "$108,382", "balance": "$203,382" },
          { "year": 20, "contributions": "$125,000", "growth": "$230,988", "balance": "$355,988" },
          { "year": 25, "contributions": "$155,000", "growth": "$450,898", "balance": "$605,898" }
        ],
        "striped": true,
        "highlightLastRow": true
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "720px", "padding": "24px" },
  "theme": { "primaryColor": "#6366f1", "backgroundColor": "#0f172a", "fontFamily": "'Inter', sans-serif", "borderRadius": "12px" }
}