{
  "title": "US Tax Bracket Calculator",
  "description": "Enter your income and see exactly how much you owe and your effective tax rate",
  "category": "finance",
  "viralHook": "Most people think they're in the 22% bracket — but your effective rate is probably much lower",
  "shareability": 5,
  "primitives": [
    {
      "type": "calculator",
      "id": "tax-calculator",
      "props": {
        "title": "Your Tax Estimate (2024)",
        "fields": [
          {
            "name": "income",
            "label": "Gross Annual Income",
            "type": "number",
            "defaultValue": 75000,
            "min": 0,
            "prefix": "$",
            "placeholder": "75000"
          },
          {
            "name": "filingStatus",
            "label": "Filing Status",
            "type": "select",
            "options": ["Single", "Married Filing Jointly", "Married Filing Separately", "Head of Household"],
            "defaultValue": "Single"
          },
          {
            "name": "deductions",
            "label": "Deduction Type",
            "type": "select",
            "options": ["Standard Deduction", "Itemized (enter amount)"],
            "defaultValue": "Standard Deduction"
          },
          {
            "name": "customDeduction",
            "label": "Itemized Deduction Amount (if applicable)",
            "type": "number",
            "defaultValue": 0,
            "min": 0,
            "prefix": "$"
          }
        ],
        "submitLabel": "Calculate My Taxes",
        "results": [
          { "label": "Federal Tax Owed", "key": "taxOwed", "format": "currency", "highlight": true },
          { "label": "Effective Tax Rate", "key": "effectiveRate", "format": "percent" },
          { "label": "Marginal Tax Bracket", "key": "marginalBracket", "format": "text" },
          { "label": "Take-Home Pay (Est.)", "key": "takeHome", "format": "currency" }
        ]
      },
      "position": 0
    },
    {
      "type": "table",
      "id": "tax-brackets-table",
      "props": {
        "title": "2024 Federal Tax Brackets (Single Filer)",
        "columns": [
          { "key": "bracket", "label": "Tax Rate", "align": "center", "width": "100px" },
          { "key": "incomeRange", "label": "Taxable Income Range", "align": "left" },
          { "key": "taxOnRange", "label": "Tax on Bracket", "align": "right" },
          { "key": "cumulative", "label": "Cumulative Max Tax", "align": "right" }
        ],
        "rows": [
          { "bracket": "10%", "incomeRange": "$0 – $11,600", "taxOnRange": "10% of amount", "cumulative": "$1,160" },
          { "bracket": "12%", "incomeRange": "$11,601 – $47,150", "taxOnRange": "12% over $11,600", "cumulative": "$5,426" },
          { "bracket": "22%", "incomeRange": "$47,151 – $100,525", "taxOnRange": "22% over $47,150", "cumulative": "$17,168" },
          { "bracket": "24%", "incomeRange": "$100,526 – $191,950", "taxOnRange": "24% over $100,525", "cumulative": "$39,110" },
          { "bracket": "32%", "incomeRange": "$191,951 – $243,725", "taxOnRange": "32% over $191,950", "cumulative": "$55,678" },
          { "bracket": "35%", "incomeRange": "$243,726 – $609,350", "taxOnRange": "35% over $243,725", "cumulative": "$183,647" },
          { "bracket": "37%", "incomeRange": "$609,351+", "taxOnRange": "37% over $609,350", "cumulative": "Unlimited" }
        ],
        "striped": true,
        "caption": "Standard deduction for single filers in 2024: $14,600. Brackets adjust annually for inflation.",
        "highlightNote": "Only income within each bracket is taxed at that rate — not your entire income."
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "760px", "padding": "24px" },
  "theme": { "primaryColor": "#3b82f6", "backgroundColor": "#0f172a", "fontFamily": "'Inter', sans-serif", "borderRadius": "12px" }
}
