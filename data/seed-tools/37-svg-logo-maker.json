{
  "title": "SVG Logo Maker",
  "description": "Create a simple logo in seconds — pick shape, colors, text, download SVG",
  "category": "creator",
  "viralHook": "Made my startup logo in 30 seconds, no Figma needed",
  "shareability": 4,
  "primitives": [
    {
      "type": "form",
      "id": "logo-config",
      "props": {
        "title": "Design Your Logo",
        "fields": [
          { "name": "text", "label": "Brand Name", "type": "text", "required": true, "placeholder": "e.g., Acme" },
          { "name": "tagline", "label": "Tagline (optional)", "type": "text", "placeholder": "e.g., Build faster" },
          { "name": "shape", "label": "Icon Shape", "type": "select", "options": ["Circle", "Rounded Square", "Hexagon", "Diamond", "Shield", "None — Text Only"], "required": true },
          { "name": "iconLetter", "label": "Icon Letter/Symbol", "type": "text", "placeholder": "e.g., A, ★, ⚡" },
          { "name": "primaryColor", "label": "Primary Color", "type": "select", "options": ["#3b82f6 Blue", "#10b981 Green", "#ef4444 Red", "#f59e0b Amber", "#8b5cf6 Purple", "#ec4899 Pink", "#0ea5e9 Sky", "#1e1e1e Black"], "required": true },
          { "name": "bgColor", "label": "Background", "type": "select", "options": ["Transparent", "#ffffff White", "#f8fafc Light Gray", "#0f172a Dark", "#1e1b4b Navy"] },
          { "name": "font", "label": "Font Style", "type": "select", "options": ["Modern (Sans)", "Classic (Serif)", "Playful (Rounded)", "Bold (Black)", "Monospace (Code)"], "required": true },
          { "name": "layout", "label": "Layout", "type": "select", "options": ["Icon Left + Text", "Icon Top + Text Below", "Text Only", "Icon Only"] }
        ],
        "submitLabel": "Generate Logo"
      },
      "position": 0
    },
    {
      "type": "card-grid",
      "id": "logo-presets",
      "props": {
        "title": "Quick Presets",
        "columns": 4,
        "cards": [
          { "title": "Tech Startup", "description": "Blue + Modern Sans", "badge": "Popular", "color": "#3b82f6" },
          { "title": "Creative Agency", "description": "Purple + Playful", "badge": "Trendy", "color": "#8b5cf6" },
          { "title": "Finance", "description": "Navy + Classic Serif", "badge": "Pro", "color": "#1e3a5f" },
          { "title": "Food & Bev", "description": "Green + Rounded", "badge": "Fresh", "color": "#10b981" },
          { "title": "Fitness", "description": "Red + Bold Black", "badge": "Strong", "color": "#ef4444" },
          { "title": "Eco / Green", "description": "Emerald + Modern", "badge": "Clean", "color": "#059669" },
          { "title": "Gaming", "description": "Pink + Dark BG", "badge": "Gamer", "color": "#ec4899" },
          { "title": "Minimal", "description": "Black + White + Mono", "badge": "Sleek", "color": "#1e1e1e" }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "640px", "padding": "24px" },
  "theme": { "primaryColor": "#3b82f6", "backgroundColor": "#f8fafc", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
