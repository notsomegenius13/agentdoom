{
  "title": "Follower Milestone Calculator",
  "description": "Input your current followers and daily growth rate — find out exactly how many days until you hit 1K, 10K, 100K, and 1M",
  "category": "social",
  "viralHook": "Most creators are 47 days from 10K and don't know it",
  "shareability": 4,
  "primitives": [
    {
      "type": "calculator",
      "id": "milestone-calc",
      "props": {
        "title": "Milestone Time Calculator",
        "inputs": [
          {
            "name": "currentFollowers",
            "label": "Current Followers",
            "type": "number",
            "defaultValue": 500,
            "min": 0,
            "step": 100,
            "placeholder": "e.g. 500"
          },
          {
            "name": "dailyGrowth",
            "label": "Avg. New Followers Per Day",
            "type": "number",
            "defaultValue": 15,
            "min": 1,
            "step": 1,
            "placeholder": "e.g. 15"
          },
          {
            "name": "platform",
            "label": "Platform",
            "type": "select",
            "options": ["Instagram", "TikTok", "Twitter/X", "YouTube", "LinkedIn"],
            "defaultValue": "Instagram"
          },
          {
            "name": "growthTrend",
            "label": "Growth Trend",
            "type": "select",
            "options": ["Flat (consistent)", "Accelerating (+5%/month)", "Viral (exponential)"],
            "defaultValue": "Flat (consistent)"
          }
        ],
        "milestones": [
          { "label": "1K Followers", "target": 1000, "icon": "🌱" },
          { "label": "10K Followers", "target": 10000, "icon": "🚀" },
          { "label": "100K Followers", "target": 100000, "icon": "💥" },
          { "label": "1M Followers", "target": 1000000, "icon": "👑" }
        ],
        "formula": "(target - currentFollowers) / dailyGrowth",
        "resultLabel": "Days to Milestone",
        "outputFormat": "milestone-table"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "growth-stats",
      "props": {
        "title": "Your Growth Snapshot",
        "stats": [
          {
            "label": "Days to 1K",
            "value": "34 days",
            "subLabel": "Est. date: May 5, 2026",
            "color": "#22c55e",
            "icon": "🌱"
          },
          {
            "label": "Days to 10K",
            "value": "633 days",
            "subLabel": "Est. date: Dec 25, 2027",
            "color": "#f59e0b",
            "icon": "🚀"
          },
          {
            "label": "Days to 100K",
            "value": "6,633 days",
            "subLabel": "Est. date: 2044 (speed up!)",
            "color": "#ef4444",
            "icon": "💥"
          },
          {
            "label": "Days to 1M",
            "value": "66,633 days",
            "subLabel": "Go viral or post more often",
            "color": "#6366f1",
            "icon": "👑"
          },
          {
            "label": "Monthly Growth",
            "value": "450 followers",
            "subLabel": "At 15/day x 30",
            "color": "#0ea5e9",
            "icon": "📈"
          },
          {
            "label": "Yearly Growth",
            "value": "5,475 followers",
            "subLabel": "By this time next year",
            "color": "#10b981",
            "icon": "📅"
          }
        ],
        "tips": [
          "💡 Posting daily vs. 3x/week can 3x your growth rate",
          "💡 Reels and short-form video typically grow accounts 5x faster",
          "💡 Collaborations with similar-sized accounts can spike growth overnight",
          "💡 Going from 1K → 10K is statistically harder than 10K → 100K",
          "💡 Consistency beats virality — 90% of big accounts grew slowly and steadily"
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "660px", "padding": "28px" },
  "theme": { "primaryColor": "#f472b6", "backgroundColor": "#0f172a", "fontFamily": "'Inter', sans-serif", "borderRadius": "14px" }
}
