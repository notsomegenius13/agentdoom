{
  "title": "CSS Gradient Generator",
  "description": "Pick two colors and generate beautiful CSS gradients instantly — copy the code and paste it anywhere",
  "category": "dev-tools",
  "viralHook": "Built a landing page hero in 30 seconds using this free gradient generator",
  "shareability": 5,
  "primitives": [
    {
      "type": "form",
      "id": "gradient-form",
      "props": {
        "title": "Build Your Gradient",
        "submitLabel": "Generate CSS",
        "fields": [
          {
            "id": "color1",
            "label": "Start Color",
            "type": "color",
            "defaultValue": "#6366f1"
          },
          {
            "id": "color2",
            "label": "End Color",
            "type": "color",
            "defaultValue": "#ec4899"
          },
          {
            "id": "angle",
            "label": "Angle (degrees)",
            "type": "number",
            "min": 0,
            "max": 360,
            "defaultValue": 135,
            "placeholder": "135"
          },
          {
            "id": "type",
            "label": "Gradient Type",
            "type": "select",
            "options": [
              { "value": "linear", "label": "Linear" },
              { "value": "radial", "label": "Radial" },
              { "value": "conic", "label": "Conic" }
            ],
            "defaultValue": "linear"
          },
          {
            "id": "prefix",
            "label": "Include vendor prefixes (-webkit-)",
            "type": "checkbox",
            "defaultValue": true
          }
        ]
      },
      "position": 0
    },
    {
      "type": "card-grid",
      "id": "preset-gradients",
      "props": {
        "title": "Preset Gradients — Click to Use",
        "columns": 3,
        "cards": [
          {
            "title": "Sunset",
            "description": "background: linear-gradient(135deg, #f97316, #ec4899)",
            "badge": "linear",
            "color": "#f97316"
          },
          {
            "title": "Ocean",
            "description": "background: linear-gradient(135deg, #06b6d4, #3b82f6)",
            "badge": "linear",
            "color": "#06b6d4"
          },
          {
            "title": "Forest",
            "description": "background: linear-gradient(135deg, #10b981, #059669)",
            "badge": "linear",
            "color": "#10b981"
          },
          {
            "title": "Aurora",
            "description": "background: linear-gradient(135deg, #6366f1, #8b5cf6, #ec4899)",
            "badge": "multi-stop",
            "color": "#8b5cf6"
          },
          {
            "title": "Midnight",
            "description": "background: linear-gradient(180deg, #0f172a, #1e293b)",
            "badge": "dark",
            "color": "#1e293b"
          },
          {
            "title": "Gold Rush",
            "description": "background: linear-gradient(135deg, #f59e0b, #fbbf24)",
            "badge": "linear",
            "color": "#f59e0b"
          },
          {
            "title": "Rose Bloom",
            "description": "background: radial-gradient(circle, #fda4af, #f43f5e)",
            "badge": "radial",
            "color": "#f43f5e"
          },
          {
            "title": "Electric",
            "description": "background: linear-gradient(90deg, #22d3ee, #6366f1)",
            "badge": "linear",
            "color": "#22d3ee"
          },
          {
            "title": "Charcoal",
            "description": "background: linear-gradient(135deg, #374151, #6b7280)",
            "badge": "dark",
            "color": "#374151"
          }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "760px", "padding": "28px" },
  "theme": { "primaryColor": "#8b5cf6", "backgroundColor": "#0f172a", "fontFamily": "'Inter', sans-serif", "borderRadius": "12px" }
}
