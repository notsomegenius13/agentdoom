{
  "title": "Browser Drum Machine",
  "description": "Make beats instantly — tap pads, loop patterns, no install needed",
  "category": "fun",
  "viralHook": "I just made a beat in 10 seconds with zero downloads",
  "shareability": 5,
  "primitives": [
    {
      "type": "card-grid",
      "id": "drum-pads",
      "props": {
        "title": "Drum Pads",
        "columns": 4,
        "cards": [
          { "title": "KICK", "description": "Deep bass kick", "badge": "1", "color": "#ef4444" },
          { "title": "SNARE", "description": "Sharp snare hit", "badge": "2", "color": "#f59e0b" },
          { "title": "HI-HAT", "description": "Closed hi-hat", "badge": "3", "color": "#10b981" },
          { "title": "OPEN HAT", "description": "Open hi-hat ring", "badge": "4", "color": "#3b82f6" },
          { "title": "CLAP", "description": "Crisp hand clap", "badge": "5", "color": "#8b5cf6" },
          { "title": "TOM", "description": "Floor tom thud", "badge": "6", "color": "#ec4899" },
          { "title": "CRASH", "description": "Cymbal crash", "badge": "7", "color": "#14b8a6" },
          { "title": "RIDE", "description": "Ride cymbal bell", "badge": "8", "color": "#f97316" },
          { "title": "COWBELL", "description": "Classic cowbell", "badge": "9", "color": "#6366f1" },
          { "title": "SHAKER", "description": "Egg shaker", "badge": "0", "color": "#84cc16" },
          { "title": "RIMSHOT", "description": "Rim click", "badge": "Q", "color": "#d946ef" },
          { "title": "PERC", "description": "Percussion hit", "badge": "W", "color": "#0ea5e9" }
        ]
      },
      "position": 0
    },
    {
      "type": "form",
      "id": "beat-settings",
      "props": {
        "title": "Beat Settings",
        "fields": [
          { "name": "bpm", "label": "BPM", "type": "number", "defaultValue": 120, "min": 60, "max": 200 },
          { "name": "swing", "label": "Swing", "type": "select", "options": ["None", "Light", "Medium", "Heavy"] },
          { "name": "kit", "label": "Kit", "type": "select", "options": ["808 Classic", "Trap", "Lo-Fi", "Rock", "Jazz Brush"] }
        ],
        "submitLabel": "Apply"
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "600px", "padding": "24px" },
  "theme": { "primaryColor": "#1e1e1e", "backgroundColor": "#111827", "fontFamily": "'JetBrains Mono', monospace", "borderRadius": "16px" }
}
