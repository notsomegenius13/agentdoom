{
  "title": "Startup Runway Calculator",
  "description": "How many months until your startup runs out of money? Find out now.",
  "category": "business",
  "viralHook": "Founders: how many months do you REALLY have left? This calculator doesn't lie.",
  "shareability": 5,
  "primitives": [
    {
      "type": "calculator",
      "id": "runway",
      "props": {
        "title": "Startup Runway Calculator",
        "inputs": [
          { "name": "bankBalance", "label": "Cash in Bank ($)", "type": "number", "defaultValue": 500000, "min": 0, "step": 10000 },
          { "name": "monthlyRevenue", "label": "Monthly Revenue ($)", "type": "number", "defaultValue": 15000, "min": 0, "step": 1000 },
          { "name": "payroll", "label": "Monthly Payroll ($)", "type": "number", "defaultValue": 45000, "min": 0, "step": 1000 },
          { "name": "rent", "label": "Monthly Rent & Ops ($)", "type": "number", "defaultValue": 5000, "min": 0, "step": 500 },
          { "name": "saas", "label": "Monthly SaaS & Tools ($)", "type": "number", "defaultValue": 3000, "min": 0, "step": 100 },
          { "name": "marketing", "label": "Monthly Marketing ($)", "type": "number", "defaultValue": 8000, "min": 0, "step": 500 },
          { "name": "revenueGrowth", "label": "Monthly Revenue Growth (%)", "type": "number", "defaultValue": 10, "min": 0, "max": 100 }
        ],
        "formula": "bankBalance / ((payroll + rent + saas + marketing) - monthlyRevenue)",
        "resultLabel": "Runway",
        "resultPrefix": "",
        "resultSuffix": " months"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "burn-stats",
      "props": {
        "title": "Burn Rate Breakdown",
        "stats": [
          { "label": "Monthly Burn", "value": "$61,000", "change": 0, "changeLabel": "total expenses", "icon": "dollar" },
          { "label": "Net Burn", "value": "$46,000", "change": -15, "changeLabel": "after revenue", "icon": "trending" },
          { "label": "Daily Burn", "value": "$1,533", "change": 0, "changeLabel": "every single day", "icon": "cart" },
          { "label": "Default Dead?", "value": "Maybe", "change": 0, "changeLabel": "at current growth rate", "icon": "percent" }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "540px", "padding": "24px" },
  "theme": { "primaryColor": "#f59e0b", "backgroundColor": "#fffbeb", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
