{
  "title": "Habit Stack",
  "description": "Track multiple daily habits, visualize streaks, see your daily score, and review weekly progress",
  "category": "productivity",
  "primitives": [
    {
      "type": "stats-dashboard",
      "id": "habit-overview",
      "props": {
        "title": "Habit Overview",
        "stats": [
          { "label": "Today's Score", "value": "5 / 8", "change": 62.5, "changeLabel": "percent", "icon": "percent" },
          { "label": "Current Streak", "value": "12 days", "change": 3, "changeLabel": "longer than avg", "icon": "trending" },
          { "label": "Best Streak", "value": "21 days", "change": 0, "changeLabel": "personal record", "icon": "cart" },
          { "label": "Weekly Avg", "value": "78%", "change": 5.4, "changeLabel": "vs last week", "icon": "percent" }
        ],
        "charts": []
      },
      "position": 0
    },
    {
      "type": "tracker",
      "id": "daily-habits",
      "props": {
        "title": "Today's Habits",
        "items": [
          { "name": "Morning meditation (10 min)", "icon": "🧘", "target": 1 },
          { "name": "Exercise (30 min)", "icon": "🏃", "target": 1 },
          { "name": "Read (20 pages)", "icon": "📚", "target": 1 },
          { "name": "Drink 8 glasses of water", "icon": "💧", "target": 8 },
          { "name": "No social media before noon", "icon": "📵", "target": 1 },
          { "name": "Journal before bed", "icon": "✍️", "target": 1 },
          { "name": "Practice gratitude (3 things)", "icon": "🙏", "target": 1 },
          { "name": "Sleep by 11 PM", "icon": "😴", "target": 1 }
        ],
        "period": "daily",
        "showStreak": true
      },
      "position": 1
    },
    {
      "type": "chart",
      "id": "weekly-scores",
      "props": {
        "title": "Daily Completion Rate This Week",
        "chartType": "bar",
        "data": [
          { "label": "Mon", "value": 87, "color": "#10b981" },
          { "label": "Tue", "value": 75, "color": "#10b981" },
          { "label": "Wed", "value": 100, "color": "#059669" },
          { "label": "Thu", "value": 62, "color": "#f59e0b" },
          { "label": "Fri", "value": 50, "color": "#ef4444" },
          { "label": "Sat", "value": 87, "color": "#10b981" },
          { "label": "Sun", "value": 75, "color": "#10b981" }
        ],
        "xLabel": "Day",
        "yLabel": "Completion %"
      },
      "position": 2
    },
    {
      "type": "checklist",
      "id": "weekly-review",
      "props": {
        "title": "Weekly Review",
        "categories": [
          { "name": "Reflect", "items": ["What went well this week?", "Which habits were hardest?", "What triggered skipped habits?"] },
          { "name": "Adjust", "items": ["Update habit targets if needed", "Identify habit stacking opportunities", "Remove or replace ineffective habits"] },
          { "name": "Plan Next Week", "items": ["Set intention for the week", "Schedule exercise sessions", "Prepare environment (books, water, journal)"] }
        ],
        "showProgress": true
      },
      "position": 3
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "900px", "padding": "24px" },
  "theme": { "primaryColor": "#10b981", "backgroundColor": "#ecfdf5", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
