{
  "title": "Recipe Manager",
  "description": "Browse recipe cards, manage ingredients, plan weekly meals, and generate shopping lists",
  "category": "health",
  "primitives": [
    {
      "type": "card-grid",
      "id": "recipe-cards",
      "props": {
        "title": "My Recipes",
        "cards": [
          { "title": "Chicken Stir Fry", "description": "30 min · 450 cal · Serves 4", "icon": "🍳", "tag": "Quick" },
          { "title": "Avocado Toast", "description": "10 min · 320 cal · Serves 1", "icon": "🥑", "tag": "Breakfast" },
          { "title": "Pasta Carbonara", "description": "25 min · 580 cal · Serves 2", "icon": "🍝", "tag": "Italian" },
          { "title": "Greek Salad", "description": "15 min · 250 cal · Serves 2", "icon": "🥗", "tag": "Healthy" },
          { "title": "Banana Smoothie", "description": "5 min · 280 cal · Serves 1", "icon": "🥤", "tag": "Breakfast" },
          { "title": "Grilled Salmon", "description": "20 min · 520 cal · Serves 2", "icon": "🐟", "tag": "Protein" },
          { "title": "Veggie Tacos", "description": "25 min · 380 cal · Serves 3", "icon": "🌮", "tag": "Mexican" },
          { "title": "Overnight Oats", "description": "5 min prep · 350 cal · Serves 1", "icon": "🥣", "tag": "Meal Prep" },
          { "title": "Teriyaki Bowl", "description": "35 min · 490 cal · Serves 2", "icon": "🍚", "tag": "Asian" }
        ],
        "columns": 3
      },
      "position": 0
    },
    {
      "type": "form",
      "id": "add-recipe",
      "props": {
        "title": "Add New Recipe",
        "fields": [
          { "name": "name", "label": "Recipe Name", "type": "text", "required": true, "placeholder": "Chicken Alfredo" },
          { "name": "category", "label": "Category", "type": "select", "options": ["Breakfast", "Lunch", "Dinner", "Snack", "Dessert", "Meal Prep"], "required": true },
          { "name": "prepTime", "label": "Prep Time (min)", "type": "number", "required": true },
          { "name": "servings", "label": "Servings", "type": "number", "required": true },
          { "name": "ingredients", "label": "Ingredients", "type": "textarea", "placeholder": "One ingredient per line", "required": true },
          { "name": "instructions", "label": "Instructions", "type": "textarea", "placeholder": "Step-by-step directions" }
        ],
        "submitLabel": "Save Recipe",
        "successMessage": "Recipe saved!"
      },
      "position": 1
    },
    {
      "type": "checklist",
      "id": "meal-plan",
      "props": {
        "title": "Weekly Meal Plan",
        "categories": [
          { "name": "Monday", "items": ["Breakfast: Overnight Oats", "Lunch: Greek Salad", "Dinner: Chicken Stir Fry"] },
          { "name": "Tuesday", "items": ["Breakfast: Avocado Toast", "Lunch: Veggie Tacos", "Dinner: Pasta Carbonara"] },
          { "name": "Wednesday", "items": ["Breakfast: Banana Smoothie", "Lunch: Teriyaki Bowl", "Dinner: Grilled Salmon"] },
          { "name": "Thursday", "items": ["Breakfast: Overnight Oats", "Lunch: Greek Salad", "Dinner: Veggie Tacos"] },
          { "name": "Friday", "items": ["Breakfast: Avocado Toast", "Lunch: Chicken Stir Fry", "Dinner: Pasta Carbonara"] }
        ],
        "showProgress": true
      },
      "position": 2
    },
    {
      "type": "list",
      "id": "shopping-list",
      "props": {
        "title": "Shopping List",
        "items": [
          "Chicken breast × 2 lbs",
          "Avocados × 4",
          "Pasta × 1 lb",
          "Eggs × 1 dozen",
          "Mixed greens × 2 bags",
          "Salmon fillets × 4",
          "Bananas × 6",
          "Oats × 1 container",
          "Feta cheese × 1 block",
          "Tortillas × 12 pack",
          "Soy sauce",
          "Teriyaki sauce"
        ],
        "addable": true,
        "removable": true,
        "reorderable": true,
        "placeholder": "Add item..."
      },
      "position": 3
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "900px", "padding": "24px" },
  "theme": { "primaryColor": "#f97316", "backgroundColor": "#fff7ed", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
