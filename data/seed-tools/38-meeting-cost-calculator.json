{
  "title": "Meeting Cost Calculator",
  "description": "See how much that meeting actually costs your company in real-time dollars",
  "category": "business",
  "viralHook": "That 1-hour all-hands with 30 people? $4,200. You're welcome.",
  "shareability": 5,
  "primitives": [
    {
      "type": "calculator",
      "id": "meeting-cost",
      "props": {
        "title": "Meeting Cost Calculator",
        "inputs": [
          { "name": "attendees", "label": "Number of Attendees", "type": "number", "defaultValue": 8, "min": 1, "max": 500 },
          { "name": "avgSalary", "label": "Avg Annual Salary ($)", "type": "number", "defaultValue": 95000, "min": 0, "step": 5000 },
          { "name": "duration", "label": "Meeting Duration (minutes)", "type": "number", "defaultValue": 60, "min": 5, "max": 480, "step": 5 },
          { "name": "frequency", "label": "Times Per Week", "type": "number", "defaultValue": 1, "min": 1, "max": 10 },
          { "name": "overhead", "label": "Overhead Multiplier", "type": "number", "defaultValue": 1.4, "min": 1, "max": 3, "step": 0.1 }
        ],
        "formula": "((avgSalary / 2080) * overhead * attendees * (duration / 60)) * frequency * 52",
        "resultLabel": "Annual Meeting Cost",
        "resultPrefix": "$",
        "resultSuffix": "/year"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "meeting-impact",
      "props": {
        "title": "What That Money Could Buy Instead",
        "stats": [
          { "label": "Per Meeting", "value": "$510", "change": 0, "changeLabel": "8 people × 1 hour", "icon": "dollar" },
          { "label": "Per Year", "value": "$26,520", "change": -100, "changeLabel": "that's a junior dev salary", "icon": "trending" },
          { "label": "Hours Burned", "value": "416 hrs", "change": 0, "changeLabel": "across all attendees/year", "icon": "percent" },
          { "label": "Productivity Lost", "value": "~2x", "change": 0, "changeLabel": "context-switching cost", "icon": "cart" }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "540px", "padding": "24px" },
  "theme": { "primaryColor": "#dc2626", "backgroundColor": "#fef2f2", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
