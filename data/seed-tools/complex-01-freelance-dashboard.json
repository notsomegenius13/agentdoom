{
  "title": "Freelance Dashboard",
  "description": "Track invoices, log time, manage clients, and visualize revenue — all in one place",
  "category": "business",
  "primitives": [
    {
      "type": "stats-dashboard",
      "id": "revenue-overview",
      "props": {
        "title": "Revenue Overview",
        "stats": [
          { "label": "Monthly Revenue", "value": "$12,450", "change": 18.2, "changeLabel": "vs last month", "icon": "dollar" },
          { "label": "Active Projects", "value": "7", "change": 2, "changeLabel": "new this month", "icon": "cart" },
          { "label": "Hours Logged", "value": "142h", "change": 5.3, "changeLabel": "vs last month", "icon": "trending" },
          { "label": "Avg Hourly Rate", "value": "$87.68", "change": 3.1, "changeLabel": "vs last month", "icon": "percent" }
        ],
        "charts": [
          {
            "type": "line",
            "title": "Weekly Revenue",
            "data": [
              { "label": "W1", "value": 2800 },
              { "label": "W2", "value": 3400 },
              { "label": "W3", "value": 2950 },
              { "label": "W4", "value": 3300 }
            ]
          }
        ]
      },
      "position": 0
    },
    {
      "type": "form",
      "id": "log-time",
      "props": {
        "title": "Log Time",
        "fields": [
          { "name": "client", "label": "Client", "type": "select", "options": ["Acme Corp", "StartupXYZ", "Design Co", "TechFlow", "MediaHub"], "required": true },
          { "name": "project", "label": "Project", "type": "text", "placeholder": "Website redesign", "required": true },
          { "name": "hours", "label": "Hours", "type": "number", "required": true },
          { "name": "rate", "label": "Rate ($/hr)", "type": "number", "required": true },
          { "name": "notes", "label": "Notes", "type": "textarea", "placeholder": "What did you work on?" }
        ],
        "submitLabel": "Log Entry",
        "successMessage": "Time logged successfully!"
      },
      "position": 1
    },
    {
      "type": "table",
      "id": "invoice-list",
      "props": {
        "title": "Recent Invoices",
        "columns": [
          { "key": "invoice", "label": "Invoice #", "sortable": true },
          { "key": "client", "label": "Client", "sortable": true },
          { "key": "amount", "label": "Amount", "sortable": true, "format": "currency" },
          { "key": "status", "label": "Status", "sortable": true },
          { "key": "due", "label": "Due Date", "sortable": true }
        ],
        "data": [
          { "invoice": "INV-047", "client": "Acme Corp", "amount": 3200, "status": "✅ Paid", "due": "2026-03-15" },
          { "invoice": "INV-048", "client": "StartupXYZ", "amount": 1800, "status": "⏳ Pending", "due": "2026-04-01" },
          { "invoice": "INV-049", "client": "Design Co", "amount": 4500, "status": "⏳ Pending", "due": "2026-04-10" },
          { "invoice": "INV-050", "client": "TechFlow", "amount": 2100, "status": "🔴 Overdue", "due": "2026-03-20" },
          { "invoice": "INV-051", "client": "MediaHub", "amount": 950, "status": "✅ Paid", "due": "2026-03-25" }
        ],
        "showSearch": true,
        "pageSize": 10
      },
      "position": 2
    },
    {
      "type": "chart",
      "id": "client-revenue",
      "props": {
        "title": "Revenue by Client",
        "chartType": "pie",
        "data": [
          { "label": "Acme Corp", "value": 3200, "color": "#3b82f6" },
          { "label": "StartupXYZ", "value": 1800, "color": "#10b981" },
          { "label": "Design Co", "value": 4500, "color": "#f59e0b" },
          { "label": "TechFlow", "value": 2100, "color": "#ef4444" },
          { "label": "MediaHub", "value": 950, "color": "#8b5cf6" }
        ]
      },
      "position": 3
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "900px", "padding": "24px" },
  "theme": { "primaryColor": "#3b82f6", "backgroundColor": "#f0f4ff", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
