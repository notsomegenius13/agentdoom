{
  "title": "Expense Tracker",
  "description": "Log and categorize daily expenses with visual breakdowns",
  "category": "money",
  "primitives": [
    {
      "type": "form",
      "id": "expense-input",
      "props": {
        "title": "Add Expense",
        "fields": [
          { "name": "description", "label": "Description", "type": "text", "required": true, "placeholder": "Coffee, lunch, etc." },
          { "name": "amount", "label": "Amount ($)", "type": "number", "required": true, "min": 0, "step": 0.01 },
          { "name": "category", "label": "Category", "type": "select", "options": ["Food & Drink", "Transport", "Shopping", "Bills", "Entertainment", "Health", "Other"], "required": true },
          { "name": "date", "label": "Date", "type": "date", "required": true }
        ],
        "submitLabel": "Add Expense"
      },
      "position": 0
    },
    {
      "type": "table",
      "id": "expense-list",
      "props": {
        "title": "Recent Expenses",
        "columns": [
          { "key": "date", "label": "Date", "sortable": true },
          { "key": "description", "label": "Description", "sortable": false },
          { "key": "category", "label": "Category", "sortable": true },
          { "key": "amount", "label": "Amount", "sortable": true, "format": "currency" }
        ],
        "data": [
          { "date": "2026-03-31", "description": "Lunch", "category": "Food & Drink", "amount": 14.50 },
          { "date": "2026-03-31", "description": "Uber", "category": "Transport", "amount": 22.00 },
          { "date": "2026-03-30", "description": "Groceries", "category": "Food & Drink", "amount": 67.30 },
          { "date": "2026-03-30", "description": "Netflix", "category": "Entertainment", "amount": 15.99 },
          { "date": "2026-03-29", "description": "Gym membership", "category": "Health", "amount": 49.00 }
        ],
        "showSearch": true,
        "pageSize": 10
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "640px", "padding": "24px" },
  "theme": { "primaryColor": "#dc2626", "backgroundColor": "#fef2f2", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}