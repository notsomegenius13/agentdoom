{
  "title": "Compound Interest Calculator",
  "description": "See how your money grows over time with the power of compound interest",
  "category": "finance",
  "viralHook": "Einstein called compound interest the eighth wonder of the world — see it working for you",
  "shareability": 5,
  "primitives": [
    {
      "type": "calculator",
      "id": "compound-inputs",
      "props": {
        "title": "Your Investment Details",
        "fields": [
          { "name": "principal", "label": "Initial Investment ($)", "type": "number", "defaultValue": 10000, "min": 0, "prefix": "$" },
          { "name": "monthlyContribution", "label": "Monthly Contribution ($)", "type": "number", "defaultValue": 500, "min": 0, "prefix": "$" },
          { "name": "annualRate", "label": "Annual Interest Rate (%)", "type": "number", "defaultValue": 7, "min": 0, "max": 100, "suffix": "%" },
          { "name": "years", "label": "Investment Period (Years)", "type": "number", "defaultValue": 20, "min": 1, "max": 50 },
          { "name": "compoundFrequency", "label": "Compounding Frequency", "type": "select", "options": ["Monthly", "Quarterly", "Annually"], "defaultValue": "Monthly" }
        ],
        "submitLabel": "Calculate Growth",
        "results": [
          { "label": "Final Balance", "key": "finalBalance", "format": "currency" },
          { "label": "Total Contributions", "key": "totalContributions", "format": "currency" },
          { "label": "Interest Earned", "key": "interestEarned", "format": "currency" },
          { "label": "Return on Investment", "key": "roi", "format": "percent" }
        ]
      },
      "position": 0
    },
    {
      "type": "table",
      "id": "compound-growth-table",
      "props": {
        "title": "Year-by-Year Breakdown",
        "columns": [
          { "key": "year", "label": "Year", "align": "center" },
          { "key": "contributions", "label": "Total Contributed", "align": "right", "format": "currency" },
          { "key": "interest", "label": "Interest Earned", "align": "right", "format": "currency" },
          { "key": "balance", "label": "Balance", "align": "right", "format": "currency" },
          { "key": "growth", "label": "Growth vs. Contributions", "align": "right", "format": "percent" }
        ],
        "rows": [
          { "year": 1, "contributions": "$16,000", "interest": "$718", "balance": "$16,718", "growth": "4.5%" },
          { "year": 2, "contributions": "$22,000", "interest": "$2,021", "balance": "$24,021", "growth": "9.2%" },
          { "year": 5, "contributions": "$40,000", "interest": "$9,654", "balance": "$49,654", "growth": "24.1%" },
          { "year": 10, "contributions": "$70,000", "interest": "$37,809", "balance": "$107,809", "growth": "54.0%" },
          { "year": 15, "contributions": "$100,000", "interest": "$93,472", "balance": "$193,472", "growth": "93.5%" },
          { "year": 20, "contributions": "$130,000", "interest": "$196,517", "balance": "$326,517", "growth": "151.2%" }
        ],
        "striped": true,
        "highlightLastRow": true
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "720px", "padding": "24px" },
  "theme": { "primaryColor": "#10b981", "backgroundColor": "#0f172a", "fontFamily": "'Inter', sans-serif", "borderRadius": "12px" }
}
