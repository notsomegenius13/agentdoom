{
  "title": "chmod Calculator",
  "description": "Toggle read, write, and execute permissions for owner, group, and other — instantly see the numeric octal and symbolic notation",
  "category": "dev-tools",
  "viralHook": "Finally understand chmod 755 vs 644 vs 777 — this calculator makes it visual",
  "shareability": 4,
  "primitives": [
    {
      "type": "form",
      "id": "chmod-form",
      "props": {
        "title": "Set File Permissions",
        "submitLabel": "Calculate chmod",
        "fields": [
          {
            "id": "owner_read",
            "label": "Owner — Read (r)",
            "type": "checkbox",
            "defaultValue": true
          },
          {
            "id": "owner_write",
            "label": "Owner — Write (w)",
            "type": "checkbox",
            "defaultValue": true
          },
          {
            "id": "owner_execute",
            "label": "Owner — Execute (x)",
            "type": "checkbox",
            "defaultValue": true
          },
          {
            "id": "group_read",
            "label": "Group — Read (r)",
            "type": "checkbox",
            "defaultValue": true
          },
          {
            "id": "group_write",
            "label": "Group — Write (w)",
            "type": "checkbox",
            "defaultValue": false
          },
          {
            "id": "group_execute",
            "label": "Group — Execute (x)",
            "type": "checkbox",
            "defaultValue": true
          },
          {
            "id": "other_read",
            "label": "Other — Read (r)",
            "type": "checkbox",
            "defaultValue": true
          },
          {
            "id": "other_write",
            "label": "Other — Write (w)",
            "type": "checkbox",
            "defaultValue": false
          },
          {
            "id": "other_execute",
            "label": "Other — Execute (x)",
            "type": "checkbox",
            "defaultValue": true
          }
        ]
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "chmod-output",
      "props": {
        "title": "Permission Output",
        "stats": [
          {
            "id": "numeric-octal",
            "label": "Numeric (Octal)",
            "value": "755",
            "icon": "hash",
            "color": "#22d3ee",
            "description": "Use with: chmod 755 filename"
          },
          {
            "id": "symbolic",
            "label": "Symbolic Notation",
            "value": "rwxr-xr-x",
            "icon": "lock",
            "color": "#10b981",
            "description": "Human-readable permission string"
          },
          {
            "id": "chmod-command",
            "label": "chmod Command",
            "value": "chmod 755 <file>",
            "icon": "terminal",
            "color": "#f59e0b",
            "description": "Ready to copy and run"
          },
          {
            "id": "common-use",
            "label": "Common Use Case",
            "value": "Executables, web dirs",
            "icon": "info",
            "color": "#8b5cf6",
            "description": "Typical context for this permission"
          }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "640px", "padding": "28px" },
  "theme": { "primaryColor": "#22d3ee", "backgroundColor": "#0f172a", "fontFamily": "'JetBrains Mono', 'Fira Code', monospace", "borderRadius": "10px" }
}
