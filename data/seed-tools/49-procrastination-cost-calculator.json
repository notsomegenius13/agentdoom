{
  "title": "Procrastination Cost Calculator",
  "description": "How much money is your procrastination actually costing you? The math is brutal.",
  "category": "productivity",
  "viralHook": "I procrastinate 2 hours a day. That's $23,400/year in lost income. I feel attacked.",
  "shareability": 5,
  "primitives": [
    {
      "type": "calculator",
      "id": "procrastination-cost",
      "props": {
        "title": "The Price of Procrastination",
        "inputs": [
          { "name": "hoursWasted", "label": "Hours Procrastinating/Day", "type": "number", "defaultValue": 2, "min": 0, "max": 8, "step": 0.5 },
          { "name": "hourlyValue", "label": "Your Hourly Value ($)", "type": "number", "defaultValue": 45, "min": 0, "step": 5 },
          { "name": "workDays", "label": "Work Days Per Week", "type": "number", "defaultValue": 5, "min": 1, "max": 7 },
          { "name": "compoundYears", "label": "Years of Procrastination", "type": "number", "defaultValue": 5, "min": 1, "max": 30 }
        ],
        "formula": "hoursWasted * hourlyValue * workDays * 52",
        "resultLabel": "Annual Cost of Procrastination",
        "resultPrefix": "$",
        "resultSuffix": "/year"
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "procrastination-stats",
      "props": {
        "title": "The Damage Report (at 2 hrs/day)",
        "stats": [
          { "label": "Weekly Loss", "value": "$450", "change": -10, "changeLabel": "gone to Reddit/Twitter", "icon": "dollar" },
          { "label": "5-Year Total", "value": "$117,000", "change": 0, "changeLabel": "lifetime so far", "icon": "trending" },
          { "label": "Hours Lost/Year", "value": "520 hrs", "change": 0, "changeLabel": "that's 65 work days", "icon": "percent" },
          { "label": "Side Projects", "value": "~3 apps", "change": 0, "changeLabel": "you could've shipped", "icon": "cart" }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "500px", "padding": "24px" },
  "theme": { "primaryColor": "#ea580c", "backgroundColor": "#fff7ed", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
