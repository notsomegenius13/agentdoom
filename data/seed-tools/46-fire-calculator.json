{
  "title": "FIRE Calculator",
  "description": "Calculate your path to Financial Independence, Retire Early — see your FIRE number and timeline",
  "category": "money",
  "viralHook": "At a 50% savings rate, you can retire in 17 years. Most people save 5%.",
  "shareability": 5,
  "primitives": [
    {
      "type": "calculator",
      "id": "fire-number",
      "props": {
        "title": "FIRE Number Calculator",
        "inputs": [
          { "name": "annualExpenses", "label": "Annual Living Expenses ($)", "type": "number", "defaultValue": 50000, "min": 0, "step": 1000 },
          { "name": "annualIncome", "label": "Annual After-Tax Income ($)", "type": "number", "defaultValue": 100000, "min": 0, "step": 5000 },
          { "name": "currentSavings", "label": "Current Investments ($)", "type": "number", "defaultValue": 75000, "min": 0, "step": 5000 },
          { "name": "withdrawalRate", "label": "Safe Withdrawal Rate (%)", "type": "number", "defaultValue": 4, "min": 2, "max": 6, "step": 0.25 },
          { "name": "returnRate", "label": "Expected Annual Return (%)", "type": "number", "defaultValue": 7, "min": 1, "max": 15, "step": 0.5 }
        ],
        "formula": "annualExpenses / (withdrawalRate / 100)",
        "resultLabel": "Your FIRE Number",
        "resultPrefix": "$",
        "resultSuffix": ""
      },
      "position": 0
    },
    {
      "type": "stats-dashboard",
      "id": "fire-stats",
      "props": {
        "title": "Your FIRE Dashboard",
        "stats": [
          { "label": "FIRE Number", "value": "$1,250,000", "change": 0, "changeLabel": "at 4% withdrawal rate", "icon": "dollar" },
          { "label": "Savings Rate", "value": "50%", "change": 0, "changeLabel": "income minus expenses", "icon": "trending" },
          { "label": "Years to FIRE", "value": "~17 years", "change": 0, "changeLabel": "at 7% annual return", "icon": "percent" },
          { "label": "Progress", "value": "6%", "change": 6, "changeLabel": "$75K of $1.25M", "icon": "cart" }
        ],
        "charts": [
          {
            "type": "bar",
            "title": "FIRE Timeline by Savings Rate",
            "data": [
              { "label": "10% savings", "value": 51 },
              { "label": "25% savings", "value": 32 },
              { "label": "50% savings", "value": 17 },
              { "label": "75% savings", "value": 7 }
            ]
          }
        ]
      },
      "position": 1
    }
  ],
  "layout": { "type": "single-column", "maxWidth": "560px", "padding": "24px" },
  "theme": { "primaryColor": "#16a34a", "backgroundColor": "#f0fdf4", "fontFamily": "system-ui, sans-serif", "borderRadius": "12px" }
}
