{
  "title": "Group Poll Maker",
  "description": "Create fun group decision polls and share them with your crew",
  "category": "social",
  "viralHook": "No more 47-message group chat debates - just send the poll!",
  "shareability": 8,
  "primitives": [
    {
      "type": "poll",
      "id": "group-poll",
      "props": {
        "title": "Where should we eat tonight?",
        "subtitle": "Vote for your pick! You can only choose one.",
        "allowMultipleVotes": false,
        "showResultsBeforeVote": false,
        "showVoterCount": true,
        "anonymousVoting": false,
        "closeable": true,
        "options": [
          {
            "id": "italian",
            "label": "Italian 🍕",
            "description": "Pizza, pasta, and good vibes",
            "color": "#E74C3C",
            "votes": 12
          },
          {
            "id": "sushi",
            "label": "Sushi 🍣",
            "description": "Fresh rolls and sashimi",
            "color": "#3498DB",
            "votes": 8
          },
          {
            "id": "mexican",
            "label": "Mexican 🌮",
            "description": "Tacos, burritos, and margaritas",
            "color": "#2ECC71",
            "votes": 15
          },
          {
            "id": "thai",
            "label": "Thai 🍜",
            "description": "Pad thai, curries, and spring rolls",
            "color": "#F39C12",
            "votes": 6
          },
          {
            "id": "burgers",
            "label": "Burgers 🍔",
            "description": "Classic burgers and fries",
            "color": "#9B59B6",
            "votes": 10
          },
          {
            "id": "indian",
            "label": "Indian 🍛",
            "description": "Curry, naan, and tikka masala",
            "color": "#E67E22",
            "votes": 9
          }
        ],
        "display": {
          "showPercentage": true,
          "showVoteCount": true,
          "barStyle": "gradient",
          "barHeight": 32,
          "animateBars": true,
          "sortByVotes": true,
          "highlightLeader": true,
          "leaderBadge": "🏆 Currently Winning"
        },
        "totalVotes": 60,
        "footer": {
          "text": "Poll closes when the group decides!",
          "showShareButton": true,
          "shareMessage": "Vote on where we should eat tonight! 🍽️"
        },
        "customization": {
          "allowCustomTitle": true,
          "titlePlaceholder": "What are we deciding?",
          "allowAddOptions": true,
          "maxOptions": 10,
          "addOptionPlaceholder": "Add another option...",
          "allowEditOptions": true
        },
        "templates": [
          {
            "id": "food",
            "label": "Where to Eat",
            "options": ["Italian 🍕", "Sushi 🍣", "Mexican 🌮", "Thai 🍜", "Burgers 🍔", "Indian 🍛"]
          },
          {
            "id": "movie",
            "label": "Movie Night",
            "options": ["Action 💥", "Comedy 😂", "Horror 👻", "Romance 💕", "Sci-Fi 🚀", "Documentary 🎬"]
          },
          {
            "id": "hangout",
            "label": "What to Do",
            "options": ["Game Night 🎲", "Karaoke 🎤", "Bowling 🎳", "Beach Day 🏖️", "Hiking 🥾", "Movie Theater 🎥"]
          },
          {
            "id": "day",
            "label": "Pick a Day",
            "options": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
          }
        ]
      }
    }
  ]
}