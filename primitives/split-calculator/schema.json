{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "SplitCalculatorConfig",
  "description": "A bill splitting calculator with tip calculation",
  "required": ["title"],
  "properties": {
    "title": { "type": "string" },
    "currency": { "type": "string" },
    "defaultTipPercent": { "type": "number" },
    "defaultPeople": { "type": "number" },
    "tipOptions": { "type": "array", "items": { "type": "number" } }
  }
}
