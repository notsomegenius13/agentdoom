{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "FileUploadConfig",
  "description": "A file upload component with drag-and-drop, type validation, and size limits",
  "required": ["title"],
  "properties": {
    "title": { "type": "string" },
    "acceptedTypes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "maxFileSizeMB": { "type": "number" },
    "maxFiles": { "type": "number" },
    "uploadLabel": { "type": "string" },
    "dragDropLabel": { "type": "string" }
  }
}
