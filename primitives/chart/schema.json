{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "ChartConfig",
  "description": "SVG-based chart supporting bar, line, and pie types",
  "required": ["title", "type", "data"],
  "properties": {
    "title": { "type": "string" },
    "type": { "type": "string", "enum": ["bar", "line", "pie"] },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "value"],
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "number" },
          "color": { "type": "string" }
        }
      }
    },
    "showLegend": { "type": "boolean", "description": "Display a color legend below the chart" },
    "showValues": { "type": "boolean", "description": "Display numeric values on the chart" },
    "width": { "type": "number", "description": "SVG viewBox width (default 400)" },
    "height": { "type": "number", "description": "SVG viewBox height (default 260)" }
  }
}
