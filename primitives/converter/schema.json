{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "ConverterConfig",
  "description": "A unit/currency converter",
  "required": ["title", "categories"],
  "properties": {
    "title": { "type": "string" },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "units"],
        "properties": {
          "name": { "type": "string" },
          "units": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "factor"],
              "properties": {
                "name": { "type": "string" },
                "factor": { "type": "number", "description": "Factor relative to base unit" }
              }
            }
          }
        }
      }
    }
  }
}
