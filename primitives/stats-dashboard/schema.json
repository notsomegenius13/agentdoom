{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "StatsDashboardConfig",
  "description": "KPI cards and charts dashboard",
  "required": ["title", "stats"],
  "properties": {
    "title": { "type": "string" },
    "stats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "value"],
        "properties": {
          "label": { "type": "string" },
          "value": { "oneOf": [{ "type": "string" }, { "type": "number" }] },
          "change": { "type": "string" },
          "changeType": { "type": "string", "enum": ["positive", "negative", "neutral"] },
          "icon": { "type": "string" }
        }
      }
    },
    "chartTitle": { "type": "string" },
    "chartType": { "type": "string", "enum": ["bar", "pie"] },
    "chartData": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "value"],
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "number" },
          "color": { "type": "string" }
        }
      }
    }
  }
}
