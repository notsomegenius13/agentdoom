{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "ToastConfig",
  "description": "A notification/toast system with color-coded messages and auto-dismiss",
  "required": ["title", "toasts"],
  "properties": {
    "title": { "type": "string" },
    "toasts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "message", "type"],
        "properties": {
          "id": { "type": "string" },
          "message": { "type": "string" },
          "type": { "type": "string", "enum": ["success", "error", "warning", "info"] }
        }
      }
    },
    "position": { "type": "string", "enum": ["top-right", "top-left", "bottom-right", "bottom-left"] },
    "autoDismiss": { "type": "boolean" },
    "dismissAfterMs": { "type": "number" }
  }
}
