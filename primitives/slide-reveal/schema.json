{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "SlideRevealConfig",
  "description": "Content slides in from an edge for tool card transitions",
  "properties": {
    "title": {
      "type": "string"
    },
    "direction": {
      "type": "string",
      "enum": [
        "left",
        "right",
        "top",
        "bottom"
      ],
      "default": "left"
    },
    "duration": {
      "type": "number",
      "minimum": 100,
      "maximum": 5000,
      "default": 600
    },
    "delay": {
      "type": "number",
      "minimum": 0,
      "default": 0
    },
    "distance": {
      "type": "number",
      "minimum": 1,
      "maximum": 200,
      "default": 40
    },
    "triggerOnView": {
      "type": "boolean",
      "default": true
    },
    "content": {
      "type": "string",
      "description": "Text content to display inside the reveal"
    },
    "appearance": {
      "type": "object",
      "description": "Visual polish: entrance animation, dark mode colors, responsive breakpoints",
      "properties": {
        "animation": {
          "type": "object",
          "properties": {
            "entrance": {
              "type": "string",
              "enum": [
                "none",
                "fade",
                "slide",
                "scale"
              ],
              "default": "none"
            },
            "duration": {
              "type": "number",
              "default": 300
            },
            "delay": {
              "type": "number",
              "default": 0
            }
          }
        },
        "darkMode": {
          "type": "object",
          "properties": {
            "background": {
              "type": "string"
            },
            "surface": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "textSecondary": {
              "type": "string"
            },
            "accent": {
              "type": "string"
            },
            "border": {
              "type": "string"
            }
          }
        },
        "responsive": {
          "type": "object",
          "properties": {
            "padding": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "maxWidth": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "fontSize": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "number"
                },
                "tablet": {
                  "type": "number"
                },
                "desktop": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}
