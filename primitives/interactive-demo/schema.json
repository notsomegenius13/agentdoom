{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InteractiveDemoConfig",
  "description": "Configuration for the InteractiveDemo composite primitive",
  "type": "object",
  "required": [
    "title",
    "examples"
  ],
  "properties": {
    "title": {
      "type": "string",
      "description": "The title displayed at the top of the demo"
    },
    "description": {
      "type": "string",
      "description": "Optional description displayed below the title"
    },
    "examples": {
      "type": "array",
      "description": "List of code examples to display",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "code"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the example"
          },
          "label": {
            "type": "string",
            "description": "Display label for the example tab"
          },
          "code": {
            "type": "string",
            "description": "The code content of the example"
          },
          "language": {
            "type": "string",
            "description": "Programming language for display purposes"
          }
        },
        "additionalProperties": false
      },
      "minItems": 0
    },
    "defaultExampleId": {
      "type": "string",
      "description": "ID of the example to display initially"
    },
    "editable": {
      "type": "boolean",
      "description": "Whether the code can be edited by the user",
      "default": false
    },
    "showLineNumbers": {
      "type": "boolean",
      "description": "Whether to display line numbers in the code gutter",
      "default": false
    },
    "previewType": {
      "type": "string",
      "enum": [
        "html",
        "text",
        "json"
      ],
      "description": "How to render the preview pane",
      "default": "html"
    },
    "appearance": {
      "type": "object",
      "description": "Visual polish: entrance animation, dark mode colors, responsive breakpoints",
      "properties": {
        "animation": {
          "type": "object",
          "properties": {
            "entrance": {
              "type": "string",
              "enum": [
                "none",
                "fade",
                "slide",
                "scale"
              ],
              "default": "none"
            },
            "duration": {
              "type": "number",
              "default": 300
            },
            "delay": {
              "type": "number",
              "default": 0
            }
          }
        },
        "darkMode": {
          "type": "object",
          "properties": {
            "background": {
              "type": "string"
            },
            "surface": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "textSecondary": {
              "type": "string"
            },
            "accent": {
              "type": "string"
            },
            "border": {
              "type": "string"
            }
          }
        },
        "responsive": {
          "type": "object",
          "properties": {
            "padding": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "maxWidth": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "fontSize": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "number"
                },
                "tablet": {
                  "type": "number"
                },
                "desktop": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
