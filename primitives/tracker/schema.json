{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "TrackerConfig",
  "description": "A habit/goal tracker with checkable items and streaks",
  "required": [
    "title",
    "items",
    "period"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "icon": {
            "type": "string",
            "description": "Emoji icon"
          },
          "target": {
            "type": "number",
            "description": "Target count per period",
            "minimum": 1
          }
        }
      }
    },
    "period": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "monthly"
      ]
    },
    "showStreak": {
      "type": "boolean",
      "default": true
    },
    "appearance": {
      "type": "object",
      "description": "Visual polish: entrance animation, dark mode colors, responsive breakpoints",
      "properties": {
        "animation": {
          "type": "object",
          "properties": {
            "entrance": {
              "type": "string",
              "enum": [
                "none",
                "fade",
                "slide",
                "scale"
              ],
              "default": "none"
            },
            "duration": {
              "type": "number",
              "default": 300
            },
            "delay": {
              "type": "number",
              "default": 0
            }
          }
        },
        "darkMode": {
          "type": "object",
          "properties": {
            "background": {
              "type": "string"
            },
            "surface": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "textSecondary": {
              "type": "string"
            },
            "accent": {
              "type": "string"
            },
            "border": {
              "type": "string"
            }
          }
        },
        "responsive": {
          "type": "object",
          "properties": {
            "padding": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "maxWidth": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "fontSize": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "number"
                },
                "tablet": {
                  "type": "number"
                },
                "desktop": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}
