{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "TypingEffectConfig",
  "description": "A typewriter text animation for tool descriptions and feed cards",
  "required": [
    "text"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "text": {
      "type": "string",
      "description": "The text to type out"
    },
    "speed": {
      "type": "number",
      "minimum": 10,
      "maximum": 500,
      "default": 50
    },
    "startDelay": {
      "type": "number",
      "minimum": 0,
      "default": 0
    },
    "cursor": {
      "type": "boolean",
      "default": true
    },
    "cursorChar": {
      "type": "string",
      "default": "|"
    },
    "loop": {
      "type": "boolean",
      "default": false
    },
    "loopDelay": {
      "type": "number",
      "minimum": 0,
      "default": 2000
    },
    "triggerOnView": {
      "type": "boolean",
      "default": true
    },
    "tag": {
      "type": "string",
      "enum": [
        "p",
        "h1",
        "h2",
        "h3",
        "span"
      ],
      "default": "p"
    },
    "appearance": {
      "type": "object",
      "description": "Visual polish: entrance animation, dark mode colors, responsive breakpoints",
      "properties": {
        "animation": {
          "type": "object",
          "properties": {
            "entrance": {
              "type": "string",
              "enum": [
                "none",
                "fade",
                "slide",
                "scale"
              ],
              "default": "none"
            },
            "duration": {
              "type": "number",
              "default": 300
            },
            "delay": {
              "type": "number",
              "default": 0
            }
          }
        },
        "darkMode": {
          "type": "object",
          "properties": {
            "background": {
              "type": "string"
            },
            "surface": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "textSecondary": {
              "type": "string"
            },
            "accent": {
              "type": "string"
            },
            "border": {
              "type": "string"
            }
          }
        },
        "responsive": {
          "type": "object",
          "properties": {
            "padding": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "maxWidth": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "fontSize": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "number"
                },
                "tablet": {
                  "type": "number"
                },
                "desktop": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}
