{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "KanbanBoardConfig",
  "description": "A kanban board with draggable cards across columns",
  "required": ["title", "columns"],
  "properties": {
    "title": { "type": "string" },
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "cards"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "cards": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title"],
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "description": { "type": "string" },
                "color": { "type": "string" },
                "assignee": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "allowAdd": { "type": "boolean" },
    "allowMove": { "type": "boolean" }
  }
}
