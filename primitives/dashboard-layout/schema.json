{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DashboardLayoutConfig",
  "description": "Configuration for the Dashboard Layout composite primitive",
  "type": "object",
  "required": [
    "title",
    "stats"
  ],
  "properties": {
    "title": {
      "type": "string",
      "description": "Main dashboard title"
    },
    "subtitle": {
      "type": "string",
      "description": "Optional subtitle displayed below the title"
    },
    "showDateFilter": {
      "type": "boolean",
      "description": "Whether to show the date range filter dropdown",
      "default": false
    },
    "stats": {
      "type": "array",
      "description": "KPI stat cards displayed in a responsive grid",
      "items": {
        "type": "object",
        "required": [
          "label",
          "value"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Stat card label"
          },
          "value": {
            "type": [
              "string",
              "number"
            ],
            "description": "Stat card value"
          },
          "change": {
            "type": "string",
            "description": "Change indicator text (e.g. '+12%')"
          },
          "changeType": {
            "type": "string",
            "enum": [
              "positive",
              "negative",
              "neutral"
            ],
            "description": "Determines the color of the change indicator"
          },
          "icon": {
            "type": "string",
            "description": "Optional emoji or icon character"
          }
        }
      }
    },
    "charts": {
      "type": "array",
      "description": "Charts displayed in a 1-2 column grid",
      "items": {
        "type": "object",
        "required": [
          "title",
          "type",
          "data"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Chart section title"
          },
          "type": {
            "type": "string",
            "enum": [
              "bar",
              "line",
              "pie"
            ],
            "description": "Chart rendering type"
          },
          "data": {
            "type": "array",
            "description": "Data points for the chart",
            "items": {
              "type": "object",
              "required": [
                "label",
                "value"
              ],
              "properties": {
                "label": {
                  "type": "string",
                  "description": "Data point label"
                },
                "value": {
                  "type": "number",
                  "description": "Data point numeric value"
                },
                "color": {
                  "type": "string",
                  "description": "Optional CSS color for this data point"
                }
              }
            }
          }
        }
      }
    },
    "tableTitle": {
      "type": "string",
      "description": "Title for the summary table section"
    },
    "tableColumns": {
      "type": "array",
      "description": "Column definitions for the summary table",
      "items": {
        "type": "object",
        "required": [
          "key",
          "label"
        ],
        "properties": {
          "key": {
            "type": "string",
            "description": "Property key to read from each row"
          },
          "label": {
            "type": "string",
            "description": "Column header display label"
          }
        }
      }
    },
    "tableRows": {
      "type": "array",
      "description": "Row data for the summary table",
      "items": {
        "type": "object",
        "additionalProperties": {
          "type": [
            "string",
            "number"
          ]
        }
      }
    },
    "appearance": {
      "type": "object",
      "description": "Visual polish: entrance animation, dark mode colors, responsive breakpoints",
      "properties": {
        "animation": {
          "type": "object",
          "properties": {
            "entrance": {
              "type": "string",
              "enum": [
                "none",
                "fade",
                "slide",
                "scale"
              ],
              "default": "none"
            },
            "duration": {
              "type": "number",
              "default": 300
            },
            "delay": {
              "type": "number",
              "default": 0
            }
          }
        },
        "darkMode": {
          "type": "object",
          "properties": {
            "background": {
              "type": "string"
            },
            "surface": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "textSecondary": {
              "type": "string"
            },
            "accent": {
              "type": "string"
            },
            "border": {
              "type": "string"
            }
          }
        },
        "responsive": {
          "type": "object",
          "properties": {
            "padding": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "maxWidth": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "fontSize": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "number"
                },
                "tablet": {
                  "type": "number"
                },
                "desktop": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}
