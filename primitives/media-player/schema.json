{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MediaPlayerConfig",
  "type": "object",
  "required": [
    "title",
    "type",
    "src"
  ],
  "properties": {
    "title": {
      "type": "string",
      "description": "The title displayed above the media player"
    },
    "type": {
      "type": "string",
      "enum": [
        "audio",
        "video"
      ],
      "description": "The type of media to play"
    },
    "src": {
      "type": "string",
      "description": "URL of the media source"
    },
    "poster": {
      "type": "string",
      "description": "URL of the poster image for video (displayed before playback)"
    },
    "autoplay": {
      "type": "boolean",
      "description": "Whether the media should start playing automatically"
    },
    "loop": {
      "type": "boolean",
      "description": "Whether the media should loop when it reaches the end"
    },
    "showControls": {
      "type": "boolean",
      "description": "Whether to show playback controls"
    },
    "appearance": {
      "type": "object",
      "description": "Visual polish: entrance animation, dark mode colors, responsive breakpoints",
      "properties": {
        "animation": {
          "type": "object",
          "properties": {
            "entrance": {
              "type": "string",
              "enum": [
                "none",
                "fade",
                "slide",
                "scale"
              ],
              "default": "none"
            },
            "duration": {
              "type": "number",
              "default": 300
            },
            "delay": {
              "type": "number",
              "default": 0
            }
          }
        },
        "darkMode": {
          "type": "object",
          "properties": {
            "background": {
              "type": "string"
            },
            "surface": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "textSecondary": {
              "type": "string"
            },
            "accent": {
              "type": "string"
            },
            "border": {
              "type": "string"
            }
          }
        },
        "responsive": {
          "type": "object",
          "properties": {
            "padding": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "maxWidth": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "fontSize": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "number"
                },
                "tablet": {
                  "type": "number"
                },
                "desktop": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
