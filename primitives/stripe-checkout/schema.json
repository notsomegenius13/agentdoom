{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StripeCheckoutConfig",
  "description": "Configuration for the Stripe Checkout button primitive",
  "type": "object",
  "required": [
    "productName",
    "priceCents"
  ],
  "properties": {
    "productName": {
      "type": "string",
      "description": "Display name of the product"
    },
    "priceCents": {
      "type": "integer",
      "minimum": 100,
      "description": "Price in cents (e.g. 1499 = $14.99)"
    },
    "stripePriceId": {
      "type": "string",
      "description": "Stripe Price ID for pre-configured products"
    },
    "currency": {
      "type": "string",
      "default": "$",
      "description": "Currency symbol"
    },
    "mode": {
      "type": "string",
      "enum": [
        "payment",
        "subscription"
      ],
      "default": "payment",
      "description": "'payment' for one-time, 'subscription' for recurring"
    },
    "checkoutApiUrl": {
      "type": "string",
      "default": "/api/stripe/checkout",
      "description": "API endpoint that creates the checkout session"
    },
    "buttonLabel": {
      "type": "string",
      "description": "Custom button label (defaults to 'Buy Now' or 'Subscribe')"
    },
    "description": {
      "type": "string",
      "description": "Optional description shown below the product name"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Additional metadata passed to the checkout session"
    },
    "successUrl": {
      "type": "string",
      "description": "Redirect URL after successful checkout"
    },
    "cancelUrl": {
      "type": "string",
      "description": "Redirect URL if checkout is cancelled"
    },
    "variant": {
      "type": "string",
      "enum": [
        "default",
        "compact",
        "card"
      ],
      "default": "default",
      "description": "Visual style variant"
    },
    "appearance": {
      "type": "object",
      "description": "Visual polish: entrance animation, dark mode colors, responsive breakpoints",
      "properties": {
        "animation": {
          "type": "object",
          "properties": {
            "entrance": {
              "type": "string",
              "enum": [
                "none",
                "fade",
                "slide",
                "scale"
              ],
              "default": "none"
            },
            "duration": {
              "type": "number",
              "default": 300
            },
            "delay": {
              "type": "number",
              "default": 0
            }
          }
        },
        "darkMode": {
          "type": "object",
          "properties": {
            "background": {
              "type": "string"
            },
            "surface": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "textSecondary": {
              "type": "string"
            },
            "accent": {
              "type": "string"
            },
            "border": {
              "type": "string"
            }
          }
        },
        "responsive": {
          "type": "object",
          "properties": {
            "padding": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "maxWidth": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "string"
                },
                "tablet": {
                  "type": "string"
                },
                "desktop": {
                  "type": "string"
                }
              }
            },
            "fontSize": {
              "type": "object",
              "properties": {
                "mobile": {
                  "type": "number"
                },
                "tablet": {
                  "type": "number"
                },
                "desktop": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}
