{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "TableConfig",
  "description": "A sortable, filterable data table",
  "required": ["title", "columns", "rows"],
  "properties": {
    "title": { "type": "string" },
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "label"],
        "properties": {
          "key": { "type": "string" },
          "label": { "type": "string" },
          "type": { "type": "string", "enum": ["text", "number", "currency"] }
        }
      }
    },
    "rows": { "type": "array", "items": { "type": "object" } },
    "searchable": { "type": "boolean" }
  }
}
